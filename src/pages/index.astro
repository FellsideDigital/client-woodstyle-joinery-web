---
// src/pages/index.astro
import BaseLayout from '../layouts/Layout.astro';
import FAQ from '../components/FAQ.astro';

const faqs = [
  {
    question: "Where does Woodstyle Joinery operate?",
    answer: "Woodstyle Joinery is based in Brisco, Carlisle, Cumbria, and serves customers across Cumbria and the wider North of England. We have completed projects as far afield as Cornwall."
  },
  {
    question: "How long has Woodstyle Joinery been in business?",
    answer: "Woodstyle Joinery was founded in 1988, giving us over 35 years of experience crafting bespoke woodwork and joinery for homes and gardens across Cumbria."
  },
  {
    question: "Do you offer a free quote?",
    answer: "Yes. Call us on 01228 512303 or send a message via our contact page for a free, no-obligation quote on your joinery project."
  },
  {
    question: "What types of bespoke joinery do you offer?",
    answer: "We offer a full range of bespoke joinery including kitchens, fitted bedrooms and dressing rooms, conservatories and orangeries, garages and workshops, garden structures, log stores, and summerhouses. Every piece is handcrafted and fully custom."
  },
  {
    question: "How does the Woodstyle design process work?",
    answer: "We use CAD software to create detailed drawings of your project before any manufacture begins. Designs are shared by email for your review and approval, with amendments made until you are completely satisfied with the plan."
  }
];
---
<BaseLayout
  title="Bespoke Joinery Carlisle, Cumbria | Woodstyle Joinery"
  description="Bespoke joinery and woodwork crafted for Cumbrian homes since 1988. Kitchens, bedrooms, conservatories, garages and more. Call 01228 512303."
>
    <!-- HERO -->
    <section class="bg-primary-custom text-white text-center py-5 py-lg-6">
      <div class="container py-5">
        <h1 class="display-5 fw-bold mb-4">
          Crafting Bespoke Woodwork Since 1988
        </h1>
        <p class="lead mb-4 mx-auto" style="max-width: 720px">
          Quality joinery for homes and gardens across Cumbria and beyond
        </p>
        <a href="contact" class="btn btn-secondary-custom btn-lg fw-bold"
          >Get a Quote</a
        >
      </div>
    </section>

    <!-- ABOUT -->
    <section class="py-5 bg-white">
      <div class="container py-5">
        <div class="row align-items-center g-5">
          <div class="col-md-6">
            <h2 class="fw-bold text-primary-custom mb-4">Our Woodwork Story</h2>
            <p class="fs-5">
              Formed in 1988 with a passion for joinery and woodwork, Woodstyle
              has become well established across Cumbria and beyond.
            </p>
            <blockquote class="border-start border-4 ps-4 fst-italic mt-4">
              “Our work is a great source of pride — the love of what we do
              comes through in every project.”
              <span class="d-block mt-2 fw-semibold">— Alan Dickinson</span>
            </blockquote>
          </div>
          <div class="col-md-6">
            <img
              src="/images/home-image.png"
              alt="Workshop"
              class="img-fluid rounded shadow"
            />
            <!-- src="http://static.photos/workspace/1200x630/42" -->
          </div>
        </div>
      </div>
    </section>

    <!-- VALUES -->
    <section class="py-5 bg-light">
      <div class="container py-5">
        <h2 class="text-center fw-bold text-primary-custom mb-5">
          Our Core Values
        </h2>
        <div class="row g-4">
          <div class="col-md-3">
            <div class="card h-100 text-center shadow-sm">
              <div class="card-body">
                <i data-feather="award" class="mb-3 text-primary-custom"></i>
                <h5 class="fw-semibold">Honesty</h5>
                <p class="mb-0">Transparent pricing and clear communication</p>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card h-100 text-center shadow-sm">
              <div class="card-body">
                <i
                  data-feather="briefcase"
                  class="mb-3 text-primary-custom"
                ></i>
                <h5 class="fw-semibold">Professionalism</h5>
                <p class="mb-0">Decades of combined experience</p>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card h-100 text-center shadow-sm">
              <div class="card-body">
                <i data-feather="eye" class="mb-3 text-primary-custom"></i>
                <h5 class="fw-semibold">Attention to Detail</h5>
                <p class="mb-0">Precision in every joint and finish</p>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card h-100 text-center shadow-sm">
              <div class="card-body">
                <i
                  data-feather="thumbs-up"
                  class="mb-3 text-primary-custom"
                ></i>
                <h5 class="fw-semibold">Job Well Done</h5>
                <p class="mb-0">We stand by our work with pride</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Featured Products -->
    <section class="py-5 bg-white">
      <div class="container py-5">
        <div class="text-center mb-5">
          <h2 class="fw-bold text-primary-custom">Our Featured Products</h2>
          <p class="text-muted fs-5 mt-2">
            Handcrafted, bespoke joinery tailored to your home and lifestyle
          </p>
        </div>

        <div class="row g-4">
          <!-- Product 1 -->
          <div class="col-md-4">
            <a href="products/kitchens" class="text-decoration-none">
              <div class="product-card rounded shadow-sm">
                <img
                  src="/images/products/kitchens/kitchen_6.jpg"
                  alt="Bespoke Kitchens"
                />
                <div class="overlay"></div>
                <div class="card-text">
                  <h5 class="fw-bold">Bespoke Kitchens</h5>
                  <span>View Gallery →</span>
                </div>
              </div>
            </a>
          </div>

          <!-- Product 2 -->
          <div class="col-md-4">
            <a href="products/bedrooms" class="text-decoration-none">
              <div class="product-card rounded shadow-sm">
                <img
                  src="/images/products/bedrooms/bedroom_1.jpg"
                  alt="Bedrooms and Dressing Rooms"
                />
                <div class="overlay"></div>
                <div class="card-text">
                  <h5 class="fw-bold">Bedrooms & Dressing Rooms</h5>
                  <span>View Gallery →</span>
                </div>
              </div>
            </a>
          </div>

          <!-- Product 3 -->
          <div class="col-md-4">
            <a href="/products/garages" class="text-decoration-none">
              <div class="product-card rounded shadow-sm">
                <img
                  src="/images/products/garages/garage_14.jpg"
                  alt="Garages and Workshops"
                />
                <div class="overlay"></div>
                <div class="card-text">
                  <h5 class="fw-bold">Garages & Workshops</h5>
                  <span>View Gallery →</span>
                </div>
              </div>
            </a>
          </div>
        </div>

        <div class="text-center mt-5">
          <a
            href="products"
            class="btn btn-secondary-custom btn-lg fw-bold px-5"
            >View All Products</a
          >
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-primary-custom text-white text-center py-5">
      <div class="container py-5">
        <h2 class="fw-bold mb-4">Ready to Start Your Project?</h2>
        <p class="lead mb-4">
          Contact us today for a free consultation and quote.
        </p>
        <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
          <a href="contact" class="btn btn-light btn-lg fw-bold">
            Get in Touch
          </a>
          <a href="tel:01228512303" class="btn btn-secondary-custom btn-lg fw-bold">
            <i data-feather="phone" class="me-2"></i> 01228 512303
          </a>
        </div>
      </div>
    </section>

    <script>
      feather.replace();
    </script>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <FAQ items={faqs} uid="home-faq" />
</BaseLayout>
