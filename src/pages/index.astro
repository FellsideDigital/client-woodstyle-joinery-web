---
// src/pages/index.astro
import BaseLayout from '../layouts/Layout.astro';
import FAQ from '../components/FAQ.astro';

const faqs = [
  {
    question: "Where does Woodstyle Joinery operate?",
    answer: "Woodstyle Joinery is based in Brisco, Carlisle, Cumbria, and serves customers across Cumbria and the wider North of England. We have completed projects as far afield as Cornwall."
  },
  {
    question: "How long has Woodstyle Joinery been in business?",
    answer: "Woodstyle Joinery was founded in 1988, giving us over 35 years of experience crafting bespoke woodwork and joinery for homes and gardens across Cumbria."
  },
  {
    question: "Do you offer a free quote?",
    answer: "Yes. Call us on 01228 512303 or send a message via our contact page for a quote on your joinery project."
  },
  {
    question: "What types of bespoke joinery do you offer?",
    answer: "We offer a full range of bespoke joinery including kitchens, fitted bedrooms and dressing rooms, conservatories and orangeries, garages and workshops, garden structures, log stores, and summerhouses. Every piece is handcrafted and fully custom."
  },
  {
    question: "How does the Woodstyle design process work?",
    answer: "We use CAD software to create detailed drawings of your project before any manufacture begins. Designs are shared by email for your review and approval, with amendments made until you are completely satisfied with the plan."
  }
];
---
<BaseLayout
  title="Bespoke Joinery Carlisle, Cumbria | Woodstyle Joinery"
  description="Bespoke joinery and woodwork crafted for Cumbrian homes since 1988. Kitchens, bedrooms, conservatories, garages and more. Call 01228 512303."
>
    <!-- HERO -->
    <section class="page-hero py-12 text-center lg:py-20">
      <div class="container py-12" data-reveal>
        <span class="hero-eyebrow">Est. 1988 · Carlisle, Cumbria</span>
        <h1 class="display-4 mx-auto mb-6 font-bold" style="max-width: 14ch">
          Bespoke Joinery, Handmade in Cumbria Since 1988
        </h1>
        <p class="lead mx-auto mb-6" style="max-width: 640px">
          Honest, handmade joinery for homes and gardens right across Cumbria. Built around you, and built to last.
        </p>
        <div class="flex flex-col justify-center gap-4 sm:flex-row">
          <a href="contact" class="btn btn-light btn-lg px-6 font-bold">Get a Quote</a>
          <a href="products" class="btn btn-outline-custom btn-lg px-6 font-bold">View Our Work</a>
        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section class="section bg-white">
      <div class="container">
        <div class="grid grid-cols-1 items-center gap-12 md:grid-cols-2">
          <div data-reveal>
            <span class="section-kicker">Since 1988</span>
            <h2 class="mb-6 font-bold text-primary-custom heading-accent">Our Woodwork Story</h2>
            <p class="text-xl">
              We set up in 1988 and have been making joinery for homes
              across Cumbria, and well beyond, ever since.
            </p>
            <blockquote class="home-quote">
              “We take real pride in our work, and we reckon the love of what we
              do shows in every job.”
              <span class="mt-4 block font-semibold">Alan Dickinson</span>
            </blockquote>
          </div>
          <div data-reveal data-reveal-delay="1">
            <img
              src="/images/home-image.png"
              alt="The Woodstyle Joinery workshop in Carlisle, Cumbria"
              class="h-auto w-full rounded-2xl shadow-xl"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Featured Products -->
    <section class="section bg-cream-deep">
      <div class="container">
        <div class="mb-12 text-center" data-reveal>
          <span class="section-kicker">Handcrafted For You</span>
          <h2 class="font-bold text-primary-custom heading-accent">Our Featured Products</h2>
          <p class="mt-4 text-xl text-muted">
            Handmade joinery, built to fit your home and the way you live
          </p>
        </div>

        <div class="featured-grid">
          <!-- Feature: Kitchens -->
          <a href="products/kitchens" class="feat-feature no-underline" data-reveal>
            <div class="product-card product-card--feature">
              <img src="/images/products/kitchens/DSC_1943-HDR.JPG" alt="Kitchen by Woodstyle Joinery" loading="lazy" />
              <div class="overlay"></div>
              <div class="card-text">
                <h5 class="font-bold">Kitchens</h5>
                <span>View Gallery →</span>
              </div>
            </div>
          </a>

          <!-- Bedrooms -->
          <a href="products/bedrooms" class="feat-side-top no-underline" data-reveal data-reveal-delay="1">
            <div class="product-card">
              <img src="/images/products/bedrooms/IMG_4151.jpeg" alt="Fitted bedroom and dressing room joinery" loading="lazy" />
              <div class="overlay"></div>
              <div class="card-text">
                <h5 class="font-bold">Bedrooms & Dressing Rooms</h5>
                <span>View Gallery →</span>
              </div>
            </div>
          </a>

          <!-- Garages -->
          <a href="products/garages-and-carports" class="feat-side-bot no-underline" data-reveal data-reveal-delay="2">
            <div class="product-card">
              <img src="/images/products/garages-and-carports/IMG_1913.jpeg" alt="Timber garage and carport" loading="lazy" />
              <div class="overlay"></div>
              <div class="card-text">
                <h5 class="font-bold">Garages & Carports</h5>
                <span>View Gallery →</span>
              </div>
            </div>
          </a>

          <!-- Conservatories (wide) -->
          <a href="products/conservatories-and-orangeries" class="feat-wide no-underline" data-reveal data-reveal-delay="3">
            <div class="product-card">
              <img src="/images/products/conservatories-and-orangeries/IMG_1856.jpeg" alt="Conservatory and orangery joinery" loading="lazy" />
              <div class="overlay"></div>
              <div class="card-text">
                <h5 class="font-bold">Conservatories & Orangeries</h5>
                <span>View Gallery →</span>
              </div>
            </div>
          </a>
        </div>

        <div class="mt-12 text-center" data-reveal>
          <a href="products" class="btn btn-secondary-custom btn-lg px-12 font-bold">View All Products</a>
        </div>
      </div>
    </section>

    <!-- Featured Project Spotlight -->
    <section class="section bg-white">
      <div class="container">
        <div class="spotlight-grid">
          <div class="spotlight-image" data-reveal>
            <img
              src="/images/products/verandas/IMG_1878.jpeg"
              alt="Oak framed veranda at Lingholm Cafe, Portinscale, Keswick"
              class="h-auto w-full rounded-2xl shadow-xl"
              loading="lazy"
            />
          </div>
          <div class="spotlight-text" data-reveal data-reveal-delay="1">
            <span class="section-kicker">Featured Project</span>
            <h2 class="mb-6 font-bold text-primary-custom heading-accent">Lingholm Cafe, Keswick</h2>
            <p class="text-xl">
              One of the best examples of our Oak Framed Verandas is situated at <a href="https://www.google.com/maps/search/?api=1&query=Lingholm+Cafe+Portinscale+Keswick+CA12+5TZ" target="_blank" rel="noopener" class="text-accent underline hover:opacity-80">Lingholm Cafe, Portinscale, Keswick, CA12 5T2</a>. This under cover eating area was created in November 2024 to provide extra capacity to the popular cafe.
            </p>
            <a href="/products/oak-framed-verandas" class="btn btn-secondary-custom btn-lg font-bold mt-8" style="width: fit-content">
              See Our Oak Framed Verandas →
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section bg-primary-custom text-center text-white">
      <div class="container" data-reveal>
        <span class="hero-eyebrow">Free Quote, No Pressure</span>
        <h2 class="mb-4 mt-2 font-bold" style="color: rgba(255,255,255,0.85)">Thinking About a Project?</h2>
        <p class="lead mx-auto mb-6" style="max-width: 540px; color: rgba(255,255,255,0.85)">
          Give us a call or drop us a line and we'll sort you out with a free quote.
        </p>
        <div class="flex flex-col justify-center gap-4 sm:flex-row">
          <a href="contact" class="btn btn-light btn-lg font-bold">
            Get in Touch
          </a>
          <a href="tel:01228512303" class="btn btn-outline-custom btn-lg font-bold">
            <i data-feather="phone" class="mr-2" aria-hidden="true"></i> 01228 512303
          </a>
        </div>
      </div>
    </section>

    <FAQ items={faqs} uid="home-faq" />

    <style>
      /* Editorial featured-products layout */
      .featured-grid {
        display: grid;
        gap: 1.5rem;
        grid-template-columns: 1fr;
      }
      @media (min-width: 992px) {
        .featured-grid {
          grid-template-columns: 1.45fr 1fr;
          grid-template-rows: 230px 230px 420px;
          grid-template-areas:
            "feature side-top"
            "feature side-bottom"
            "wide    wide";
        }
        .featured-grid .feat-feature  { grid-area: feature; }
        .featured-grid .feat-side-top { grid-area: side-top; }
        .featured-grid .feat-side-bot { grid-area: side-bottom; }
        .featured-grid .feat-wide     { grid-area: wide; }
        .featured-grid .product-card  { height: 100%; }
        .product-card--feature .card-text { padding: 2rem; }
        .product-card--feature .card-text h5 { font-size: 1.9rem; }
      }

      .home-quote {
        margin-top: 1.75rem;
        padding: 1.25rem 1.5rem;
        border-left: 4px solid var(--accent);
        background: var(--cream);
        border-radius: 0 var(--radius-md) var(--radius-md) 0;
        font-family: var(--font-heading);
        font-style: italic;
        font-size: 1.15rem;
        color: var(--ink);
      }
      .home-quote span {
        font-family: var(--font-body);
        font-style: normal;
        font-size: 0.95rem;
        color: var(--ink-muted);
      }

      .spotlight-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem;
        align-items: center;
      }
      @media (min-width: 768px) {
        .spotlight-grid {
          grid-template-columns: 1fr 1fr;
        }
      }
      .spotlight-image img {
        aspect-ratio: 4 / 3;
        object-fit: cover;
      }
    </style>
</BaseLayout>
