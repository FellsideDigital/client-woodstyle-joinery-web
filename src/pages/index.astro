---
// src/pages/index.astro
import BaseLayout from '../layouts/Layout.astro';
import FAQ from '../components/FAQ.astro';

const faqs = [
  {
    question: "Where does Woodstyle Joinery operate?",
    answer: "Woodstyle Joinery is based in Brisco, Carlisle, Cumbria, and serves customers across Cumbria and the wider North of England. We have completed projects as far afield as Cornwall."
  },
  {
    question: "How long has Woodstyle Joinery been in business?",
    answer: "Woodstyle Joinery was founded in 1988, giving us over 35 years of experience crafting bespoke woodwork and joinery for homes and gardens across Cumbria."
  },
  {
    question: "Do you offer a free quote?",
    answer: "Yes. Call us on 01228 512303 or send a message via our contact page for a free, no-obligation quote on your joinery project."
  },
  {
    question: "What types of bespoke joinery do you offer?",
    answer: "We offer a full range of bespoke joinery including kitchens, fitted bedrooms and dressing rooms, conservatories and orangeries, garages and workshops, garden structures, log stores, and summerhouses. Every piece is handcrafted and fully custom."
  },
  {
    question: "How does the Woodstyle design process work?",
    answer: "We use CAD software to create detailed drawings of your project before any manufacture begins. Designs are shared by email for your review and approval, with amendments made until you are completely satisfied with the plan."
  }
];
---
<BaseLayout
  title="Bespoke Joinery Carlisle, Cumbria | Woodstyle Joinery"
  description="Bespoke joinery and woodwork crafted for Cumbrian homes since 1988. Kitchens, bedrooms, conservatories, garages and more. Call 01228 512303."
>
    <!-- HERO -->
    <section class="page-hero text-center py-5 py-lg-6">
      <div class="container py-5" data-reveal>
        <span class="hero-eyebrow">Est. 1988 · Carlisle, Cumbria</span>
        <h1 class="display-4 fw-bold mb-4 mx-auto" style="max-width: 14ch">
          Crafting Bespoke Woodwork Since 1988
        </h1>
        <p class="lead mb-4 mx-auto" style="max-width: 640px">
          Quality joinery for homes and gardens across Cumbria and beyond — designed around you, built to last.
        </p>
        <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
          <a href="contact" class="btn btn-light btn-lg fw-bold px-4">Get a Quote</a>
          <a href="products" class="btn btn-outline-custom btn-lg fw-bold px-4">View Our Work</a>
        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section class="section bg-white">
      <div class="container">
        <div class="row align-items-center g-5">
          <div class="col-md-6" data-reveal>
            <span class="section-kicker">Since 1988</span>
            <h2 class="fw-bold text-primary-custom heading-accent mb-4">Our Woodwork Story</h2>
            <p class="fs-5">
              Formed in 1988 with a passion for joinery and woodwork, Woodstyle
              has become well established across Cumbria and beyond.
            </p>
            <blockquote class="home-quote">
              “Our work is a great source of pride — the love of what we do
              comes through in every project.”
              <span class="d-block mt-3 fw-semibold">— Alan Dickinson</span>
            </blockquote>
          </div>
          <div class="col-md-6" data-reveal data-reveal-delay="1">
            <img
              src="/images/home-image.png"
              alt="The Woodstyle Joinery workshop in Carlisle, Cumbria"
              class="img-fluid rounded-4 shadow"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- STATS -->
    <section class="bg-cream-deep py-4 py-lg-5">
      <div class="container">
        <div class="stat-strip" data-reveal>
          <div class="stat-item">
            <span class="stat-num">35+</span>
            <span class="stat-label">Years Crafting</span>
          </div>
          <div class="stat-item">
            <span class="stat-num">500+</span>
            <span class="stat-label">Projects Built</span>
          </div>
          <div class="stat-item">
            <span class="stat-num">100%</span>
            <span class="stat-label">Bespoke Work</span>
          </div>
          <div class="stat-item">
            <span class="stat-num">10+</span>
            <span class="stat-label">Skilled Joiners</span>
          </div>
        </div>
      </div>
    </section>

    <!-- VALUES -->
    <section class="section bg-light">
      <div class="container">
        <div class="text-center mb-5" data-reveal>
          <span class="section-kicker">What Drives Us</span>
          <h2 class="fw-bold text-primary-custom heading-accent">Our Core Values</h2>
        </div>
        <div class="row g-4">
          <div class="col-sm-6 col-md-3" data-reveal>
            <div class="value-card h-100 text-center p-4">
              <div class="icon-badge mx-auto"><i data-feather="award" aria-hidden="true"></i></div>
              <h5 class="fw-semibold">Honesty</h5>
              <p class="mb-0 text-muted">Transparent pricing and clear communication</p>
            </div>
          </div>
          <div class="col-sm-6 col-md-3" data-reveal data-reveal-delay="1">
            <div class="value-card h-100 text-center p-4">
              <div class="icon-badge mx-auto"><i data-feather="briefcase" aria-hidden="true"></i></div>
              <h5 class="fw-semibold">Professionalism</h5>
              <p class="mb-0 text-muted">Decades of combined experience</p>
            </div>
          </div>
          <div class="col-sm-6 col-md-3" data-reveal data-reveal-delay="2">
            <div class="value-card h-100 text-center p-4">
              <div class="icon-badge mx-auto"><i data-feather="eye" aria-hidden="true"></i></div>
              <h5 class="fw-semibold">Attention to Detail</h5>
              <p class="mb-0 text-muted">Precision in every joint and finish</p>
            </div>
          </div>
          <div class="col-sm-6 col-md-3" data-reveal data-reveal-delay="3">
            <div class="value-card h-100 text-center p-4">
              <div class="icon-badge mx-auto"><i data-feather="thumbs-up" aria-hidden="true"></i></div>
              <h5 class="fw-semibold">Job Well Done</h5>
              <p class="mb-0 text-muted">We stand by our work with pride</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Featured Products -->
    <section class="section bg-white">
      <div class="container">
        <div class="text-center mb-5" data-reveal>
          <span class="section-kicker">Handcrafted For You</span>
          <h2 class="fw-bold text-primary-custom heading-accent">Our Featured Products</h2>
          <p class="text-muted fs-5 mt-3">
            Handcrafted, bespoke joinery tailored to your home and lifestyle
          </p>
        </div>

        <div class="row g-4">
          <!-- Product 1 -->
          <div class="col-md-4" data-reveal>
            <a href="products/kitchens" class="text-decoration-none">
              <div class="product-card">
                <img src="/images/products/kitchens/kitchen_6.jpg" alt="Bespoke kitchen by Woodstyle Joinery" loading="lazy" />
                <div class="overlay"></div>
                <div class="card-text">
                  <h5 class="fw-bold">Bespoke Kitchens</h5>
                  <span>View Gallery →</span>
                </div>
              </div>
            </a>
          </div>

          <!-- Product 2 -->
          <div class="col-md-4" data-reveal data-reveal-delay="1">
            <a href="products/bedrooms" class="text-decoration-none">
              <div class="product-card">
                <img src="/images/products/bedrooms/bedroom_1.jpg" alt="Fitted bedroom and dressing room joinery" loading="lazy" />
                <div class="overlay"></div>
                <div class="card-text">
                  <h5 class="fw-bold">Bedrooms & Dressing Rooms</h5>
                  <span>View Gallery →</span>
                </div>
              </div>
            </a>
          </div>

          <!-- Product 3 -->
          <div class="col-md-4" data-reveal data-reveal-delay="2">
            <a href="/products/garages" class="text-decoration-none">
              <div class="product-card">
                <img src="/images/products/garages/garage_14.jpg" alt="Bespoke timber garage and workshop" loading="lazy" />
                <div class="overlay"></div>
                <div class="card-text">
                  <h5 class="fw-bold">Garages & Workshops</h5>
                  <span>View Gallery →</span>
                </div>
              </div>
            </a>
          </div>
        </div>

        <div class="text-center mt-5" data-reveal>
          <a href="products" class="btn btn-secondary-custom btn-lg fw-bold px-5">View All Products</a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-primary-custom text-white text-center section">
      <div class="container" data-reveal>
        <span class="hero-eyebrow">Free, No-Obligation Quote</span>
        <h2 class="fw-bold mb-3 mt-2 text-white">Ready to Start Your Project?</h2>
        <p class="lead mb-4 mx-auto" style="max-width: 540px; color: rgba(255,255,255,0.85)">
          Contact us today for a free consultation and quote.
        </p>
        <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
          <a href="contact" class="btn btn-light btn-lg fw-bold">
            Get in Touch
          </a>
          <a href="tel:01228512303" class="btn btn-outline-custom btn-lg fw-bold">
            <i data-feather="phone" class="me-2" aria-hidden="true"></i> 01228 512303
          </a>
        </div>
      </div>
    </section>

    <FAQ items={faqs} uid="home-faq" />

    <style>
      .home-quote {
        margin-top: 1.75rem;
        padding: 1.25rem 1.5rem;
        border-left: 4px solid var(--accent);
        background: var(--cream);
        border-radius: 0 var(--radius-md) var(--radius-md) 0;
        font-family: var(--font-heading);
        font-style: italic;
        font-size: 1.15rem;
        color: var(--ink);
      }
      .home-quote span {
        font-family: var(--font-body);
        font-style: normal;
        font-size: 0.95rem;
        color: var(--ink-muted);
      }
    </style>
</BaseLayout>
