---
// src/pages/design-services.astro
import Layout from '../layouts/Layout.astro';
import DesignServicesCarousel from '../components/DesignServicesCarousel.astro';

const title = "Joinery Design Services | Woodstyle Joinery Carlisle";
const description = "CAD-designed bespoke joinery tailored to your home. From clever storage solutions to garden rooms — Woodstyle Joinery brings your ideas to life.";
---

<Layout title={title} description={description}>

  <!-- Hero Section -->
  <section class="page-hero text-center py-12 mb-12">
    <div class="container py-12" data-reveal>
      <span class="hero-eyebrow">CAD-Designed · Built To Fit</span>
      <h1 class="display-5 font-bold">Joinery Design Services</h1>
      <p class="lead mx-auto" style="max-width: 640px">From clever storage solutions to garden rooms — we bring your ideas to life with detailed CAD drawings before a single cut is made.</p>
    </div>
  </section>

  <!-- Text Section -->
  <section class="container py-12">
    <div class="mx-auto" style="max-width: 760px" data-reveal>
    <span class="section-kicker">How It Works</span>
    <h2 class="font-bold text-primary-custom heading-accent mb-6">Design Service</h2>
    <p class="text-xl mb-4">
      We use the latest CAD software to plan your joinery project and create drawings for your approval before manufacture goes ahead. Throughout the design process, alterations and additions can be easily added whilst maintaining accuracy, which is crucial to producing a quality finish.
    </p>
    <p class="text-xl mb-4">
      Our experience in designing for the home and garden optimizes the space available; whether that is clever storage solutions such as wardrobes, cupboards and closets or a garden structure that compliments the existing landscape and features. Designs can be communicated and amended back and forth via email at a time that suits you so that the designing of your bespoke project can be of minimum inconvenience and instead the exciting experience it is supposed to be of creating something as unique as you are!
    </p>
    <p class="text-xl mb-4">
      Please don't hesitate to give us a call if you would like to discuss an idea or enquire about a quote.
    </p>
    <p class="text-xl mb-4">
      Look forward to hearing from you.<br/>
      <strong>The Woodstyle Team</strong>
    </p>
    </div>
  </section>

  <!-- Carousel Section -->
  <section class="container pb-12">
    <div class="text-center mb-12" data-reveal>
      <span class="section-kicker">What We Design</span>
      <h2 class="font-bold text-primary-custom heading-accent">Ideas We Bring To Life</h2>
    </div>
    <div data-reveal>
      <DesignServicesCarousel />
    </div>
  </section>

  <!-- Call to Action -->
  <section class="text-center section bg-cream-deep">
    <div class="container" data-reveal>
      <h2 class="font-bold text-primary-custom mb-4">Have an Idea in Mind?</h2>
      <p class="lead mx-auto mb-6" style="max-width: 520px">
        Let’s turn it into a detailed CAD design built to fit your space.
      </p>
      <a href="/contact" class="btn btn-secondary-custom btn-lg font-bold">
        Contact Us About Your Design
      </a>
    </div>
  </section>

</Layout>
