---
// src/pages/design-services.astro
import Layout from '../layouts/Layout.astro';
import DesignServicesCarousel from '../components/DesignServicesCarousel.astro';

const title = "Joinery Design Services | Woodstyle Joinery Carlisle";
const description = "CAD-designed bespoke joinery, from clever storage to garden rooms. Drawn up and made to fit by Woodstyle Joinery in Cumbria.";
---

<Layout title={title} description={description}>

  <!-- Hero Section -->
  <section class="page-hero text-center py-12 mb-12">
    <div class="container py-12" data-reveal>
      <span class="hero-eyebrow">CAD-Designed · Built To Fit</span>
      <h1 class="display-5 font-bold">Joinery Design Services</h1>
      <p class="lead mx-auto" style="max-width: 640px">From clever storage to garden rooms, we draw it all up in CAD and get it right with you before we make a single cut.</p>
    </div>
  </section>

  <!-- Text Section -->
  <section class="container py-12">
    <div class="mx-auto" style="max-width: 760px" data-reveal>
    <span class="section-kicker">How It Works</span>
    <h2 class="font-bold text-primary-custom heading-accent mb-6">Design Service</h2>
    <p class="text-xl mb-4">
      We use CAD software to plan your project and draw it all up for you to approve before we make anything. You can tweak and add bits as we go, and because everything's accurate from the start, you get a proper quality finish at the end.
    </p>
    <p class="text-xl mb-4">
      Years of designing for the home and garden mean we know how to make the most of the space you've got, whether that's wardrobes, cupboards and closets indoors, or a garden building that sits right alongside what's already there. We can send designs back and forth by email whenever suits you, so planning your project is straightforward rather than a faff.
    </p>
    <p class="text-xl mb-4">
      If you've got an idea or fancy a quote, give us a call. We're always happy to talk it through.
    </p>
    <p class="text-xl mb-4">
      Look forward to hearing from you.<br/>
      <strong>The Woodstyle Team</strong>
    </p>
    </div>
  </section>

  <!-- Carousel Section -->
  <section class="container pb-12">
    <div class="text-center mb-12" data-reveal>
      <span class="section-kicker">What We Design</span>
      <h2 class="font-bold text-primary-custom heading-accent">Ideas We Bring To Life</h2>
    </div>
    <div data-reveal>
      <DesignServicesCarousel />
    </div>
  </section>

  <!-- Call to Action -->
  <section class="text-center section bg-cream-deep">
    <div class="container" data-reveal>
      <h2 class="font-bold text-primary-custom mb-4">Got Something in Mind?</h2>
      <p class="lead mx-auto mb-6" style="max-width: 520px">
        Tell us about it and we'll draw it up to fit your space.
      </p>
      <a href="/contact" class="btn btn-secondary-custom btn-lg font-bold">
        Contact Us About Your Design
      </a>
    </div>
  </section>

</Layout>
