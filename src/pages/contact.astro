---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';

const title = "Contact Woodstyle Joinery | Carlisle, Cumbria";
const description = "Get in touch with Woodstyle Joinery for a free quote on bespoke joinery in Carlisle, Cumbria. Call 01228 512303 or send us a message.";
---

<Layout title={title} description={description}>
  <!-- Hero Section -->
  <section class="page-hero text-center py-5 mb-5">
    <div class="container py-4" data-reveal>
      <span class="hero-eyebrow">Get In Touch</span>
      <h1 class="display-5 fw-bold mb-3">Let's Talk About Your Project</h1>
      <p class="lead mx-auto mb-0" style="max-width: 640px">Get in touch with Woodstyle Joinery for a free, no-obligation quote on bespoke joinery in Carlisle, Cumbria.</p>
    </div>
  </section>

  <section class="container mb-5">
    <div class="row g-5 align-items-start">
      <!-- Contact Info -->
      <div class="col-md-4" data-reveal>
        <div class="sidebar-card p-4 rounded-4 shadow-sm h-100">
          <h5 class="fw-bold text-primary-custom mb-4">Our Details</h5>
          <p class="mb-3 d-flex align-items-start gap-2">
            <i data-feather="phone" class="contact-icon mt-1"></i>
            <a href="tel:01228512303" class="text-decoration-none text-dark fw-medium">01228 512303</a>
          </p>
          <p class="mb-3 d-flex align-items-start gap-2">
            <i data-feather="mail" class="contact-icon mt-1"></i>
            <a href="mailto:info@woodstylejoinery.co.uk" class="text-decoration-none text-dark fw-medium">info@woodstylejoinery.co.uk</a>
          </p>
          <p class="mb-0 d-flex align-items-start gap-2">
            <i data-feather="map-pin" class="contact-icon mt-1"></i>
            <span>
              Wood Bank Farm, Brisco<br />
              Carlisle, Cumbria<br />
              United Kingdom, CA4 0QP
            </span>
          </p>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="col-md-8" data-reveal data-reveal-delay="1">
        <form id="contact-form" class="sidebar-card p-4 p-md-5 rounded-4 shadow-sm" action="https://formspree.io/f/maypnvja" method="POST">
          <h5 class="fw-bold text-primary-custom mb-4">Send Us a Message</h5>
          <div class="mb-3">
            <label for="name" class="form-label">Your Name</label>
            <input type="text" class="form-control" id="name" name="name" placeholder="John Doe" autocomplete="name" required />
          </div>
          <div class="mb-3">
            <label for="email" class="form-label">Email Address</label>
            <input type="email" class="form-control" id="email" name="_replyto" placeholder="you@example.com" autocomplete="email" inputmode="email" required />
          </div>
          <div class="mb-3">
            <label for="message" class="form-label">Message</label>
            <textarea class="form-control" id="message" name="message" rows="6" placeholder="Tell us about your project..." required></textarea>
          </div>
          <button type="submit" class="btn btn-secondary-custom btn-lg fw-bold">
            Send Message
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- Google Map -->
  <section class="mb-5">
    <div class="container rounded overflow-hidden shadow-sm">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d9184.100506198445!2d-2.9058588!3d54.8673699!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0xb434ee10cfa99758!2sWoodstyle%20Joinery!5e0!3m2!1sen!2suk!4v1573475225953!5m2!1sen!2suk"
        width="100%"
        height="450"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>
  </section>

  <!-- Call to Action -->
    <section class="page-hero text-center py-5">
      <div class="container py-5">
      <h2 class="fw-bold mb-4">Ready to Discuss Your Project?</h2>
      <p class="lead mb-4 mx-auto" style="max-width: 560px">Call us or send a message today, and let's bring your dream build to life.</p>
      <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
        <a href="tel:01228512303" class="btn btn-light btn-lg fw-bold">
          <i data-feather="phone" class="me-2"></i> Call 01228 512303
        </a>
        <a href="#contact-form" class="btn btn-outline-custom btn-lg fw-bold">
          Send a Message
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    stroke: var(--primary);
  }
</style>
