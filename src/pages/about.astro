---
import Layout from '../layouts/Layout.astro';

const title = "About Woodstyle Joinery | Bespoke Joiners in Carlisle";
const description = "Learn about Woodstyle Joinery — handcrafting bespoke woodwork across Cumbria since 1988. Quality craftsmanship with a personal touch.";
---

<Layout title={title} description={description}>
  <!-- HERO -->
  <section class="page-hero text-center py-12 mb-12">
    <div class="container py-12" data-reveal>
      <span class="hero-eyebrow">Our Story</span>
      <h1 class="display-5 font-bold">About Woodstyle Joinery</h1>
      <p class="lead mx-auto" style="max-width: 640px">Handcrafting bespoke woodwork across Cumbria since 1988 — quality craftsmanship with a personal touch.</p>
    </div>
  </section>

  <!-- MAIN CONTENT -->
  <section class="container py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <!-- Text Column -->
      <div class="lg:col-span-2" data-reveal>
        <span class="section-kicker">Since 1988</span>
        <h2 class="font-bold text-primary-custom heading-accent mb-6">Our Story</h2>
        <p class="text-xl mb-6">
          Woodstyle Joinery has been handcrafting high-quality woodwork for the Cumbrian community since 1988. 
          What started as a passion for beautifully crafted pieces for homes has grown into a full-service business, 
          designing custom woodwork for both interiors and exteriors.
        </p>
        <p class="text-xl mb-6">
          We take pride in every piece we create, whether large or small. Each project receives the same attention to detail, 
          quality craftsmanship, and outstanding customer service.
        </p>
        <p class="text-xl mb-6">
          Every piece is fully customizable in wood type, style, stain, paint, and detailing. We have a large portfolio 
          to inspire your selection, or we can work with you to create a completely bespoke design.
        </p>
        <p class="text-xl mb-6">
          If you don’t see the piece you envisioned, let us know! We love crafting custom designs for your home. 
          Call us today at <a href="tel:01228512303" class="text-primary-custom font-bold">01228 512303</a> with any questions.
        </p>
      </div>

      <!-- Sidebar -->
      <div data-reveal data-reveal-delay="1">
        <!-- Impact Box -->
        <div class="sidebar-card mb-6 p-6 rounded-lg shadow-sm">
          <h5 class="font-bold text-primary-custom mb-4">Our Impact</h5>
          <ul class="list-none pl-0 mb-0 text-base impact-list">
            <li class="mb-4 flex items-center gap-4">
              <i data-feather="tool" class="impact-icon"></i>
              <span><strong>35+</strong> Years of Craftsmanship</span>
            </li>
            <li class="mb-4 flex items-center gap-4">
              <i data-feather="home" class="impact-icon"></i>
              <span><strong>500+</strong> Completed Projects</span>
            </li>
            <li class="mb-4 flex items-center gap-4">
              <i data-feather="star" class="impact-icon"></i>
              <span><strong>100%</strong> Customer Satisfaction</span>
            </li>
            <li class="mb-0 flex items-center gap-4">
              <i data-feather="users" class="impact-icon"></i>
              <span><strong>10+</strong> Skilled Joiners</span>
            </li>
          </ul>
        </div>

        <!-- Quick Links Box -->
        <div class="sidebar-card p-6 rounded-lg shadow-sm">
          <h5 class="font-bold text-primary-custom mb-4">Explore More</h5>
          <ul class="list-none pl-0 mb-0 text-base">
            <li class="mb-2">
              <a href="/testimonials" class="sidebar-link inline-flex items-center gap-2">
                <i data-feather="arrow-right" class="sidebar-link-icon"></i> Client Testimonials
              </a>
            </li>
            <li class="mb-2">
              <a href="/products" class="sidebar-link inline-flex items-center gap-2">
                <i data-feather="arrow-right" class="sidebar-link-icon"></i> Products
              </a>
            </li>
            <li class="mb-2">
              <a href="/design" class="sidebar-link inline-flex items-center gap-2">
                <i data-feather="arrow-right" class="sidebar-link-icon"></i> Design Services
              </a>
            </li>
            <li class="mb-0">
              <a href="/contact" class="sidebar-link inline-flex items-center gap-2">
                <i data-feather="arrow-right" class="sidebar-link-icon"></i> Contact Us
              </a>
            </li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <style>
    .impact-icon {
      width: 20px;
      height: 20px;
      flex-shrink: 0;
      stroke: var(--primary);
      background: rgba(85, 105, 86, 0.1);
      border-radius: 8px;
      padding: 8px;
      box-sizing: content-box;
    }
    .impact-list strong {
      color: var(--ink);
    }
    .sidebar-link {
      color: var(--ink-muted);
      text-decoration: none;
      font-weight: 500;
      transition: color 0.2s var(--ease), gap 0.2s var(--ease);
    }
    .sidebar-link:hover {
      color: var(--primary);
      gap: 0.65rem !important;
    }
    .sidebar-link-icon {
      width: 15px;
      height: 15px;
      stroke: var(--accent);
      transition: transform 0.2s var(--ease);
    }
    .sidebar-link:hover .sidebar-link-icon {
      transform: translateX(2px);
    }
  </style>
</Layout>
