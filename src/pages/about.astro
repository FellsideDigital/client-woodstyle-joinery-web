---
import Layout from '../layouts/Layout.astro';

const title = "About Woodstyle Joinery | Bespoke Joiners in Carlisle";
const description = "Woodstyle Joinery is a family-run workshop near Carlisle, handcrafting bespoke woodwork across Cumbria since 1988.";
---

<Layout title={title} description={description}>
  <!-- HERO -->
  <section class="page-hero text-center py-12 mb-12">
    <div class="container py-12" data-reveal>
      <span class="hero-eyebrow">Our Story</span>
      <h1 class="display-5 font-bold">About Woodstyle Joinery</h1>
      <p class="lead mx-auto" style="max-width: 640px">A family-run joinery workshop near Carlisle, handcrafting bespoke woodwork across Cumbria since 1988.</p>
    </div>
  </section>

  <!-- MAIN CONTENT -->
  <section class="container py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <!-- Text Column -->
      <div class="lg:col-span-2" data-reveal>
        <span class="section-kicker">Since 1988</span>
        <h2 class="font-bold text-primary-custom heading-accent mb-6">Our Story</h2>
        <p class="text-xl mb-6">
          We've been crafting woodwork for homes across Cumbria since 1988. What began as one
          joiner with a workshop and a love of the trade has grown into a trusted family team,
          making bespoke pieces for inside the home and out in the garden.
        </p>
        <p class="text-xl mb-6">
          Big job or small, every piece gets the same care and attention. We don't cut corners,
          and we treat every project as if it were going into our own home.
        </p>
        <p class="text-xl mb-6">
          Everything is made to order, so you choose the timber, the style, the finish and all
          the little details. Have a look through our work for inspiration, or come to us with
          your own ideas and we'll bring them to life.
        </p>
        <p class="text-xl mb-6">
          Can't see quite what you're after? Just ask. We're always happy to take on something
          new. Give us a call on <a href="tel:01228512303" class="text-primary-custom font-bold">01228 512303</a> and we'll have a chat.
        </p>
      </div>

      <!-- Sidebar -->
      <div data-reveal data-reveal-delay="1">
        <!-- Visit / Contact Box -->
        <div class="sidebar-card mb-6 p-6 rounded-lg shadow-sm">
          <h5 class="font-bold text-primary-custom mb-4">Pop In or Get in Touch</h5>
          <ul class="list-none pl-0 mb-0 text-base contact-list">
            <li class="mb-4 flex items-start gap-3">
              <i data-feather="phone" class="contact-icon"></i>
              <a href="tel:01228512303" class="contact-link">01228 512303</a>
            </li>
            <li class="mb-4 flex items-start gap-3">
              <i data-feather="mail" class="contact-icon"></i>
              <a href="mailto:joiners@woodstylejoinery.co.uk" class="contact-link">joiners@woodstylejoinery.co.uk</a>
            </li>
            <li class="mb-4 flex items-start gap-3">
              <i data-feather="map-pin" class="contact-icon"></i>
              <span>Wood Bank Farm, Brisco<br />Carlisle, Cumbria CA4 0QP</span>
            </li>
            <li class="mb-0 flex items-start gap-3">
              <i data-feather="clock" class="contact-icon"></i>
              <span>Mon–Fri&nbsp;&nbsp;9am – 5pm</span>
            </li>
          </ul>
        </div>

        <!-- Quick Links Box -->
        <div class="sidebar-card p-6 rounded-lg shadow-sm">
          <h5 class="font-bold text-primary-custom mb-4">Explore More</h5>
          <ul class="list-none pl-0 mb-0 text-base">
            <li class="mb-2">
              <a href="/testimonials" class="sidebar-link inline-flex items-center gap-2">
                <i data-feather="arrow-right" class="sidebar-link-icon"></i> Client Testimonials
              </a>
            </li>
            <li class="mb-2">
              <a href="/products" class="sidebar-link inline-flex items-center gap-2">
                <i data-feather="arrow-right" class="sidebar-link-icon"></i> Products
              </a>
            </li>
            <li class="mb-2">
              <a href="/design" class="sidebar-link inline-flex items-center gap-2">
                <i data-feather="arrow-right" class="sidebar-link-icon"></i> Design Services
              </a>
            </li>
            <li class="mb-0">
              <a href="/contact" class="sidebar-link inline-flex items-center gap-2">
                <i data-feather="arrow-right" class="sidebar-link-icon"></i> Contact Us
              </a>
            </li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <style>
    .contact-icon {
      width: 18px;
      height: 18px;
      flex-shrink: 0;
      margin-top: 4px;
      stroke: var(--primary);
      background: rgba(85, 105, 86, 0.1);
      border-radius: 8px;
      padding: 7px;
      box-sizing: content-box;
    }
    .contact-link {
      color: var(--ink-muted);
      text-decoration: none;
      font-weight: 500;
      word-break: break-word;
      transition: color 0.2s var(--ease);
    }
    .contact-link:hover {
      color: var(--primary);
    }
    .sidebar-link {
      color: var(--ink-muted);
      text-decoration: none;
      font-weight: 500;
      transition: color 0.2s var(--ease), gap 0.2s var(--ease);
    }
    .sidebar-link:hover {
      color: var(--primary);
      gap: 0.65rem !important;
    }
    .sidebar-link-icon {
      width: 15px;
      height: 15px;
      stroke: var(--accent);
      transition: transform 0.2s var(--ease);
    }
    .sidebar-link:hover .sidebar-link-icon {
      transform: translateX(2px);
    }
  </style>
</Layout>
