---
import Layout from '../layouts/Layout.astro';

const title = "About Woodstyle Joinery";
const description = "Handcrafting your woodworked pieces with quality & care since 1988.";
---

<Layout title={title} description={description}>
  <!-- HERO -->
  <section class="bg-primary-custom text-white text-center py-5 mb-5">
    <div class="container py-5">
      <h1 class="display-5 fw-bold">{title}</h1>
      <p class="lead mx-auto" style="max-width: 720px">{description}</p>
    </div>
  </section>

  <!-- MAIN CONTENT -->
  <section class="container py-5">
    <div class="row g-5">
      <!-- Text Column -->
      <div class="col-lg-8">
        <h2 class="fw-bold text-primary-custom mb-4">Our Story</h2>
        <p class="fs-5 mb-4">
          Woodstyle Joinery has been handcrafting high-quality woodwork for the Cumbrian community since 1988. 
          What started as a passion for beautifully crafted pieces for homes has grown into a full-service business, 
          designing custom woodwork for both interiors and exteriors.
        </p>
        <p class="fs-5 mb-4">
          We take pride in every piece we create, whether large or small. Each project receives the same attention to detail, 
          quality craftsmanship, and outstanding customer service.
        </p>
        <p class="fs-5 mb-4">
          Every piece is fully customizable in wood type, style, stain, paint, and detailing. We have a large portfolio 
          to inspire your selection, or we can work with you to create a completely bespoke design.
        </p>
        <p class="fs-5 mb-4">
          If you don’t see the piece you envisioned, let us know! We love crafting custom designs for your home. 
          Call us today at <a href="tel:01228512303" class="text-primary-custom fw-bold">01228 512303</a> with any questions.
        </p>
      </div>

      <!-- Sidebar -->
      <div class="col-lg-4">
        <!-- Impact Box -->
        <div class="sidebar-card mb-4 p-4 rounded shadow-sm bg-light">
          <h5 class="fw-bold text-primary-custom mb-3">Our Impact</h5>
          <ul class="list-unstyled mb-0 fs-6">
            <li class="mb-2"><span class="me-2">🛠️</span><strong class="me-1">35+</strong>Years of Craftsmanship</li>
            <li class="mb-2"><span class="me-2">🏡</span><strong class="me-1">500+</strong>Completed Projects</li>
            <li class="mb-2"><span class="me-2">⭐</span><strong class="me-1">100%</strong>Customer Satisfaction</li>
            <li class="mb-2"><span class="me-2">👷‍♂️</span><strong class="me-1">10+</strong>Skilled Joiners</li>
          </ul>
        </div>

        <!-- Quick Links Box -->
        <div class="sidebar-card p-4 rounded shadow-sm bg-light">
          <h5 class="fw-bold text-primary-custom mb-3">Explore More</h5>
          <ul class="list-unstyled mb-0 fs-6">
            <li class="mb-2">
              <a href="/testimonials" class="sidebar-link">
                Client Testimonials
              </a>
            </li>
            <li class="mb-2">
              <a href="/products" class="sidebar-link">
                Products
              </a>
            </li>
            <li class="mb-2">
              <a href="/design" class="sidebar-link">
                Design Services
              </a>
            </li>
            <li class="mb-2">
              <a href="/contact" class="sidebar-link">
                Contact Us
              </a>
            </li>
          </ul>
        </div>
       
      </div>
    </div>
  </section>

  <style>
    .sidebar-card {
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .sidebar-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 20px rgba(0,0,0,0.12);
    }
    .sidebar-card ul li {
      display: flex;
      align-items: center;
    }
    .sidebar-card ul li span {
      font-size: 1.25rem;
    }
    .sidebar-card ul li a {
      display: flex;
      align-items: center;
    }
    .sidebar-link {
      color: #556956; /* primary green */
      text-decoration: underline;
      text-decoration-thickness: 1px;
      transition: color 0.2s ease;
    }
    .sidebar-link:hover {
      color: #8b9d83; /* secondary green on hover */
    }
  </style>
</Layout>
