---
import BaseLayout from '../../layouts/Layout.astro';

const title = "Bespoke Joinery Products | Woodstyle Joinery Carlisle";
const description = "Browse our full range of bespoke joinery: kitchens, bedrooms, conservatories, garages and more. Handcrafted in Carlisle, Cumbria.";

const products = [
  {
    title: "Bespoke Kitchens",
    href: "/products/kitchens",
    image: "/images/products/kitchens/kitchen_6.jpg",
    alt: "Bespoke Kitchens"
  },
  {
    title: "Bedrooms & Dressing Rooms",
    href: "/products/bedrooms",
    image: "/images/products/bedrooms/bedroom_1.jpg",
    alt: "Bedrooms and Dressing Rooms"
  },
  {
    title: "Garages & Workshops",
    href: "/products/garages",
    image: "/images/products/garages/garage_14.jpg",
    alt: "Garages and Workshops"
  },
  {
    title: "Conservatories & Orangeries",
    href: "/products/conservatories",
    image: "/images/products/conservatories/conservatory_1.jpg",
    alt: "Conservatories and Orangeries"
  },
];
---

<BaseLayout title={title} description={description}>

  <!-- Hero Section -->
  <section class="page-hero text-center py-5 mb-5">
    <div class="container py-5">
      <span class="hero-eyebrow">Our Products</span>
      <h1 class="display-5 fw-bold">Bespoke Joinery, Built Around You</h1>
      <p class="lead mx-auto" style="max-width: 640px">Browse our range of handcrafted joinery — every piece designed and built to fit your home, in Carlisle and across Cumbria.</p>
    </div>
  </section>

  <!-- Products Grid -->
  <section class="section bg-white">
    <div class="container">
      <div class="text-center mb-5" data-reveal>
        <span class="section-kicker">The Full Range</span>
        <h2 class="fw-bold text-primary-custom heading-accent">Explore Our Joinery</h2>
      </div>
      <div class="row g-4">
        {products.map((product, i) => (
          <div class="col-sm-6 col-lg-4" data-reveal data-reveal-delay={(i % 3).toString()}>
            <a href={product.href} class="text-decoration-none">
              <div class="product-card">
                <img src={product.image} alt={product.alt} loading="lazy" />
                <div class="overlay"></div>
                <div class="card-text">
                  <h5 class="fw-bold">{product.title}</h5>
                  <span>View Gallery →</span>
                </div>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
