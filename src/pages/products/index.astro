---
import BaseLayout from '../../layouts/Layout.astro';

const title = "Bespoke Joinery Products | Woodstyle Joinery Carlisle";
const description = "Browse our full range of bespoke joinery: kitchens, bedrooms, conservatories, garages and more. Handcrafted in Carlisle, Cumbria.";

const products = [
  {
    title: "Bespoke Kitchens",
    href: "/products/kitchens",
    image: "/images/products/kitchens/kitchen_6.jpg",
    alt: "Bespoke Kitchens"
  },
  {
    title: "Bedrooms & Dressing Rooms",
    href: "/products/bedrooms",
    image: "/images/products/bedrooms/bedroom_1.jpg",
    alt: "Bedrooms and Dressing Rooms"
  },
  {
    title: "Garages & Workshops",
    href: "/products/garages",
    image: "/images/products/garages/garage_14.jpg",
    alt: "Garages and Workshops"
  },
  {
    title: "Conservatories & Orangeries",
    href: "/products/conservatories",
    image: "/images/products/conservatories/conservatory_1.jpg",
    alt: "Conservatories and Orangeries"
  },
  {
    title: "Summerhouses & Garden Rooms",
    href: "/products/summerhouses",
    image: "/images/products/summerhouses/269f67fb-13e4-4892-a39e-08928eee35f8.jpg",
    alt: "Summerhouses and Garden Rooms"
  },
  {
    title: "Verandas",
    href: "/products/verandas",
    image: "/images/products/verandas/4295f66f-eef6-4652-a46d-9516afd6baba.jpg",
    alt: "Verandas"
  },
  {
    title: "Porches",
    href: "/products/porches",
    image: "/images/products/porches/1bd87d91-fd38-47a6-8393-f6d27a4dce57.jpg",
    alt: "Porches"
  },
  {
    title: "Sheds & Workshops",
    href: "/products/sheds",
    image: "/images/products/sheds/196f54ba-e35d-4a82-a387-4ed23a63fed2.jpg",
    alt: "Sheds and Workshops"
  },
  {
    title: "Log Stores",
    href: "/products/logstores",
    image: "/images/products/logstores/1c3c77d8-c530-4377-b793-057d4bafac52.jpg",
    alt: "Log Stores"
  },
  {
    title: "Bespoke Projects",
    href: "/products/bespoke",
    image: "/images/products/bespoke/0f5f9d77-4f2b-4c9c-a8ec-8af8dafc5fbc.jpg",
    alt: "Bespoke Joinery Projects"
  },
];
---

<BaseLayout title={title} description={description}>

  <!-- Hero Section -->
  <section class="page-hero text-center py-12 mb-12">
    <div class="container py-12">
      <span class="hero-eyebrow">Our Products</span>
      <h1 class="display-5 font-bold">Bespoke Joinery, Built Around You</h1>
      <p class="lead mx-auto" style="max-width: 640px">Have a look through our handmade joinery. Every piece is designed and built to fit your home, here in Carlisle and right across Cumbria.</p>
    </div>
  </section>

  <!-- Products Grid -->
  <section class="section bg-white">
    <div class="container">
      <div class="text-center mb-12" data-reveal>
        <span class="section-kicker">The Full Range</span>
        <h2 class="font-bold text-primary-custom heading-accent">Explore Our Joinery</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {products.map((product, i) => (
          <div data-reveal data-reveal-delay={(i % 3).toString()}>
            <a href={product.href} class="no-underline">
              <div class="product-card">
                <img src={product.image} alt={product.alt} loading="lazy" />
                <div class="overlay"></div>
                <div class="card-text">
                  <h5 class="font-bold">{product.title}</h5>
                  <span>View Gallery →</span>
                </div>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
