---
import BaseLayout from '../../layouts/Layout.astro';

const title = "Bespoke Joinery Products | Woodstyle Joinery Carlisle";
const description = "Browse our full range of bespoke joinery: kitchens, bedrooms, conservatories, garages and more. Handcrafted in Carlisle, Cumbria.";

const products = [
  {
    title: "Kitchens",
    href: "/products/kitchens",
    image: "/images/products/kitchens/DSC_1943-HDR.JPG",
    alt: "Kitchens"
  },
  {
    title: "Bedrooms & Dressing Rooms",
    href: "/products/bedrooms",
    image: "/images/products/bedrooms/IMG_2242.jpeg",
    alt: "Bedrooms and Dressing Rooms"
  },
  {
    title: "Garages & Carports",
    href: "/products/garages-and-carports",
    image: "/images/products/garages-and-carports/IMG_1913.jpeg",
    alt: "Garages and Carports"
  },
  {
    title: "Conservatories & Orangeries",
    href: "/products/conservatories-and-orangeries",
    image: "/images/products/conservatories-and-orangeries/IMG_0120.jpeg",
    alt: "Conservatories and Orangeries"
  },
  {
    title: "Summerhouses & Garden Rooms",
    href: "/products/summerhouses-and-garden-rooms",
    image: "/images/products/summerhouses-and-garden-rooms/IMG_1456_2.jpeg",
    alt: "Summerhouses and Garden Rooms"
  },
  {
    title: "Oak-Framed Verandas",
    href: "/products/oak-framed-verandas",
    image: "/images/products/verandas/IMG_0548.jpeg",
    alt: "Oak-Framed Verandas"
  },
  {
    title: "Porches",
    href: "/products/porches",
    image: "/images/products/porches/IMG_4418.jpeg",
    alt: "Porches"
  },
  {
    title: "Pergolas & Arbours",
    href: "/products/pergolas-and-arbours",
    image: "/images/products/pergolas-and-arbours/IMG_0081.jpeg",
    alt: "Pergolas and Arbours"
  },
  {
    title: "Outdoor Eating",
    href: "/products/outdoor-eating",
    image: "/images/products/outdoor-eating/IMG_0065.jpeg",
    alt: "Outdoor Eating Areas"
  },
  {
    title: "Sheds",
    href: "/products/sheds",
    image: "/images/products/sheds/196f54ba-e35d-4a82-a387-4ed23a63fed2.jpg",
    alt: "Sheds"
  },
  {
    title: "Log Stores",
    href: "/products/logstores",
    image: "/images/products/logstores/IMG_0422.jpeg",
    alt: "Log Stores"
  },
  {
    title: "Bespoke Joinery",
    href: "/products/bespoke",
    image: "/images/products/bespoke/IMG_7863.jpeg",
    alt: "Bespoke Joinery Projects"
  },
];
---

<BaseLayout title={title} description={description}>

  <!-- Hero Section -->
  <section class="page-hero text-center py-12 mb-12">
    <div class="container py-12">
      <span class="hero-eyebrow">Our Products</span>
      <h1 class="display-5 font-bold">Bespoke Joinery, Built Around You</h1>
      <p class="lead mx-auto" style="max-width: 640px">Have a look through our handmade joinery. Every piece is designed and built to fit your home, here in Carlisle and right across Cumbria.</p>
    </div>
  </section>

  <!-- Sale banner -->
  <section class="container mb-4 mt-[-2rem]" data-reveal>
    <a href="/products/sale" class="sale-banner">
      <span class="sale-banner-tag">On Sale Now</span>
      <span class="sale-banner-text">Click to view our sale items.</span>
      <span class="sale-banner-arrow">→</span>
    </a>
  </section>

  <!-- Products Grid -->
  <section class="section bg-white">
    <div class="container">
      <div class="text-center mb-12" data-reveal>
        <span class="section-kicker">The Full Range</span>
        <h2 class="font-bold text-primary-custom heading-accent">Explore Our Joinery</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {products.map((product, i) => (
          <div data-reveal data-reveal-delay={(i % 3).toString()}>
            <a href={product.href} class="no-underline">
              <div class="product-card">
                <img src={product.image} alt={product.alt} loading="lazy" />
                <div class="overlay"></div>
                <div class="card-text">
                  <h5 class="font-bold">{product.title}</h5>
                  <span>View Gallery →</span>
                </div>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.sale-banner {
  display: flex;
  align-items: center;
  gap: 1rem;
  background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
  color: #fff;
  text-decoration: none;
  border-radius: var(--radius-md);
  padding: 1.25rem 1.75rem;
  box-shadow: var(--shadow-accent);
  transition: transform .25s var(--ease-out), box-shadow .25s var(--ease);
}
.sale-banner:hover {
  transform: translateY(-3px);
  box-shadow: 0 20px 50px rgba(168, 124, 79, 0.4);
  color: #fff;
}

.sale-banner-tag {
  flex-shrink: 0;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  background: rgba(255,255,255,0.22);
  border: 1px solid rgba(255,255,255,0.35);
  border-radius: var(--radius-pill);
  padding: 0.3rem 0.75rem;
}

.sale-banner-text {
  flex: 1;
  font-family: var(--font-heading);
  font-size: clamp(1.1rem, 2.2vw, 1.4rem);
  font-weight: 600;
  line-height: 1.2;
}

.sale-banner-arrow {
  flex-shrink: 0;
  font-size: 1.5rem;
  opacity: 0.85;
  transition: transform .25s var(--ease-out);
}
.sale-banner:hover .sale-banner-arrow {
  transform: translateX(5px);
  opacity: 1;
}
</style>
