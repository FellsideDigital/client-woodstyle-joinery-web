---
import ProductLayout from '../../layouts/ProductLayout.astro';
import FAQ from '../../components/FAQ.astro';

const title = "Oak Garages & Carports Carlisle | Woodstyle Joinery";
const description = "Custom oak-framed garages and carports in Cumbria. Single, double, and bespoke designs with integrated storage and workshop space.";

const faqs = [
  {
    question: "What types of garages does Woodstyle Joinery build?",
    answer: "We build single and double garages, oak-framed garages, garages with carports, and integrated garage-workshop combinations. Additional features such as log stores, garden sheds, and hobby workshops can also be incorporated into your design."
  },
  {
    question: "Are oak-framed garages durable?",
    answer: "Yes. Oak is naturally resistant to rot and can last for centuries when properly maintained. Oak-framed garages are an extremely durable, long-lasting investment that also adds significant aesthetic value and kerb appeal to your property."
  },
  {
    question: "Can I have a combined garage and carport in Cumbria?",
    answer: "Absolutely. We design layouts to suit what you need, whether that's enclosed parking, an open carport, a workshop, or a combination of all three. Every structure is bespoke and built to your requirements."
  },
  {
    question: "How do I get a quote for a garage in Carlisle?",
    answer: "Call us on 01228 512303 or complete our contact form. We will arrange a consultation to discuss your space, requirements, and preferred design before providing a detailed quote."
  }
];

