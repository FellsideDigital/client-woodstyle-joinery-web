---
import ProductLayout from '../../layouts/ProductLayout.astro';
import FAQ from '../../components/FAQ.astro';

const title = "Bespoke Kitchens Carlisle, Cumbria | Woodstyle Joinery";
const description = "Bespoke handcrafted kitchens in Carlisle, Cumbria. Farmhouse, shaker, and contemporary styles with custom islands and clever storage solutions.";

const faqs = [
  {
    question: "What kitchen styles does Woodstyle Joinery offer?",
    answer: "We design and build kitchens in a wide range of styles including farmhouse, shaker, contemporary, and rustic designs. Every kitchen is fully bespoke — customisable in wood type, style, paint, stain, and hardware — and tailored to your home and budget."
  },
  {
    question: "Can Woodstyle Joinery design and build a kitchen island?",
    answer: "Yes. Custom kitchen islands are one of our specialities, designed for practicality, easy cleaning, and enhanced storage. Islands can include built-in appliances, breakfast bars, and custom drawers, and can be incorporated into any kitchen layout."
  },
  {
    question: "Do you offer bespoke kitchen storage solutions?",
    answer: "Absolutely. Every cupboard and drawer in our kitchens is designed to make the most of your available space — from deep pan drawers and plate racks to integrated appliance housings and larder units."
  },
  {
    question: "How do I get a quote for a bespoke kitchen in Carlisle or Cumbria?",
    answer: "Call us on 01228 512303 or use our contact form to arrange a free, no-obligation consultation. We will discuss your ideal layout, style, and requirements before preparing a detailed design and quote."
  }
];

const images = [
  { src: "/images/products/kitchens/kitchen_1.jpg", alt: "Modern oak kitchen cabinets", caption: "Modern Oak Cabinets" },
  { src: "/images/products/kitchens/kitchen_2.jpg", alt: "Kitchen with large farmhouse sink", caption: "Farmhouse Sink Kitchen" },
  { src: "/images/products/kitchens/kitchen_3.jpg", alt: "Custom marble kitchen island", caption: "Marble Kitchen Island" },
  { src: "/images/products/kitchens/kitchen_4.jpg", alt: "Sleek contemporary kitchen design", caption: "Contemporary Kitchen" },
  { src: "/images/products/kitchens/kitchen_5.jpg", alt: "Traditional shaker style kitchen", caption: "Shaker Style Kitchen" },
  { src: "/images/products/kitchens/kitchen_6.jpg", alt: "Kitchen with clever storage solutions", caption: "Smart Storage Kitchen" },
  { src: "/images/products/kitchens/kitchen_7.jpg", alt: "Rustic farmhouse kitchen with wooden beams", caption: "Rustic Farmhouse Kitchen" },
  { src: "/images/products/kitchens/kitchen_8.jpg", alt: "Custom cabinetry with handleless doors", caption: "Handleless Custom Cabinets" },
  { src: "/images/products/kitchens/kitchen_9.jpg", alt: "Kitchen with central breakfast bar", caption: "Breakfast Bar Kitchen" },
  { src: "/images/products/kitchens/kitchen_10.jpg", alt: "Minimalist white modern kitchen", caption: "Minimalist White Kitchen" },
  { src: "/images/products/kitchens/kitchen_11.jpg", alt: "Open-plan kitchen with island", caption: "Open-Plan Kitchen" },
  { src: "/images/products/kitchens/kitchen_12.jpg", alt: "Kitchen with integrated appliances", caption: "Integrated Appliances Kitchen" },
  { src: "/images/products/kitchens/kitchen_13.jpg", alt: "Luxury kitchen with pendant lighting", caption: "Luxury Kitchen Lighting" },
  { src: "/images/products/kitchens/kitchen_15.jpg", alt: "Kitchen with bespoke cabinetry and island", caption: "Bespoke Kitchen Island" },
  { src: "/images/products/kitchens/kitchen_14.jpg", alt: "Traditional kitchen with wooden accents", caption: "Classic Wooden Kitchen" },
];
---

<ProductLayout {title} heading="Bespoke Kitchens" {description} {images} {faqs}>
  <div class="text-xl">
    <p>Kitchens are the heart of any home. A well-designed kitchen maximizes space, combines functionality with style, and provides a comfortable space to cook and entertain. Our bespoke kitchens are crafted to suit both modern and traditional tastes, tailored perfectly to your home.</p>

    <p>Farmhouse and shaker kitchens remain popular for a timeless, classic feel. Our custom kitchen islands are designed for easy cleaning, practicality, and enhanced storage. Every cupboard and drawer is designed to make the most of your space, from plates and pans to appliances and gadgets.</p>

    <p>Whether you prefer a rustic farmhouse style, a sleek modern design, or a combination of both, our team will bring your dream kitchen to life. Contact us on <strong>01228 512303</strong> to discuss your ideal layout and design.</p>

    <h3 class="mt-12 mb-4">What We Offer</h3>
    <ul class="feature-list mb-2">
      <li>Modern, traditional, and farmhouse kitchens</li>
      <li>Custom kitchen islands for functionality and style</li>
      <li>Optimised storage solutions for plates, pans, and appliances</li>
      <li>High-quality bespoke cabinetry tailored to your home</li>
      <li>Designs that maximise space while maintaining aesthetic appeal</li>
    </ul>
  </div>
</ProductLayout>
