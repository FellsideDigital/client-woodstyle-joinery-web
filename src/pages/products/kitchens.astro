  { src: "/images/products/kitchens/IMG_3669.jpg", alt: "Shaker style kitchen", caption: "Shaker Style Kitchen" },
  { src: "/images/products/kitchens/IMG_3675.jpg", alt: "Kitchen with larder unit", caption: "Kitchen with Larder" },
  { src: "/images/products/kitchens/IMG_3831.jpg", alt: "Handmade kitchen with worktop", caption: "Handmade Kitchen" },
