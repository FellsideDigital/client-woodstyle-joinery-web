  { src: "/images/products/kitchens/IMG_1154.JPG", alt: "Traditional timber kitchen", caption: "Traditional Timber Kitchen" },
  { src: "/images/products/kitchens/IMG_2347.jpg", alt: "Modern kitchen design", caption: "Modern Kitchen" },
  { src: "/images/products/kitchens/IMG_2350.jpg", alt: "Contemporary kitchen", caption: "Contemporary Kitchen" },
