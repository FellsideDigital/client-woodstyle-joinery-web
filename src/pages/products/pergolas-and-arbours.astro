---
import ProductLayout from '../../layouts/ProductLayout.astro';

const title = "Pergolas & Arbours Carlisle, Cumbria | Woodstyle Joinery";
const description = "Handcrafted timber pergolas and arbours in Carlisle, Cumbria. Beautiful garden structures that create shade, shelter, and a focal point in your outdoor space.";

const faqs = [
  {
    question: "What is the difference between a pergola and an arbour?",
    answer: "A pergola is typically a larger open-roofed structure supported by posts, creating a shaded walkway or seating area. An arbour is a smaller, more intimate structure, often arched, used as a garden seat or decorative focal point. We build both to suit your garden."
  },
  {
    question: "Will a pergola add value to my home?",
    answer: "A well-built timber pergola adds visual appeal and usable outdoor space to any garden, which buyers tend to value. More immediately, it gives you somewhere genuinely enjoyable to spend time outside."
  },
  {
    question: "Can climbing plants grow up a pergola?",
    answer: "Yes, and they look great. We design our pergolas and arbours with climbing plants in mind, using materials and spacings that suit wisteria, roses, clematis, and other climbers."
  },
  {
    question: "How do I get a quote for a pergola or arbour in Carlisle or Cumbria?",
    answer: "Call us on 01228 512303 or use our contact form. We will arrange a consultation to discuss your garden and design ideas."
  }
];

const images = [
  { src: "/images/products/pergolas-and-arbours/810d4e81-a306-4daf-97bb-c5cc8571278b.jpeg", alt: "Timber pergola or arbour by Woodstyle Joinery", caption: "Timber Pergola" },
  { src: "/images/products/pergolas-and-arbours/Arbour%20vii.jpeg", alt: "Garden arbour by Woodstyle Joinery", caption: "Garden Arbour" },
  { src: "/images/products/pergolas-and-arbours/IMGP3026.jpeg", alt: "Timber pergola or arbour by Woodstyle Joinery", caption: "Oak Pergola" },
