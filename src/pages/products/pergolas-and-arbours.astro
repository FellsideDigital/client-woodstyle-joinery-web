  { src: "/images/products/pergolas-and-arbours/IMG_0083.jpeg", alt: "Timber pergola or arbour by Woodstyle Joinery", caption: "Garden Arbour" },
  { src: "/images/products/pergolas-and-arbours/IMG_0417.jpeg", alt: "Timber pergola or arbour by Woodstyle Joinery", caption: "Oak Pergola" },
  { src: "/images/products/pergolas-and-arbours/IMG_0490.jpeg", alt: "Timber pergola or arbour by Woodstyle Joinery", caption: "Timber Pergola" },
  { src: "/images/products/pergolas-and-arbours/IMG_20210804_164632.jpeg", alt: "Timber pergola or arbour by Woodstyle Joinery", caption: "Garden Arbour" },
