  { src: "/images/products/conservatories-and-orangeries/IMG_2260.jpeg", alt: "Conservatory or orangery by Woodstyle Joinery", caption: "Victorian Conservatory" },
  { src: "/images/products/conservatories-and-orangeries/IMG_2336.jpeg", alt: "Conservatory or orangery by Woodstyle Joinery", caption: "Oak-Framed Orangery" },
  { src: "/images/products/conservatories-and-orangeries/IMG_2342.jpeg", alt: "Conservatory or orangery by Woodstyle Joinery", caption: "Hardwood Conservatory" },
  { src: "/images/products/conservatories-and-orangeries/IMG_2344.jpeg", alt: "Conservatory or orangery by Woodstyle Joinery", caption: "Classical Orangery" },
