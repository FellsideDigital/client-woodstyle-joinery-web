---
import ProductLayout from '../../layouts/ProductLayout.astro';

const title = "Outdoor Eating Areas Carlisle, Cumbria | Woodstyle Joinery";
const description = "Handcrafted outdoor eating areas and dining spaces in Carlisle, Cumbria. Timber structures designed to bring your garden to life for al fresco dining year-round.";

const faqs = [
  {
    question: "What kind of outdoor eating structures do you build?",
    answer: "We build covered dining areas, outdoor kitchen structures, pergolas with dining decks, and sheltered seating spaces. Everything is designed to suit your garden and the way you like to eat outside."
  },
  {
    question: "Can an outdoor eating area be used in bad weather?",
    answer: "With a solid roof and optional side screens or glazing, yes. We design covered structures that give you genuine shelter, so you're not confined to sunny days to get the most out of your garden."
  },
  {
    question: "Can you add lighting and power to an outdoor dining area?",
    answer: "We build in provision for lighting and power runs so you can dine outside in the evenings. Final electrical connections are best left to a qualified electrician, and we plan the layout to suit."
  },
  {
    question: "How do I get a quote for an outdoor eating area in Carlisle or Cumbria?",
    answer: "Call us on 01228 512303 or use our contact form. Tell us roughly what you have in mind and we will arrange a consultation."
  }
];

