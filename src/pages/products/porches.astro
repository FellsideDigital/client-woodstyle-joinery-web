---
import ProductLayout from '../../layouts/ProductLayout.astro';

const title = "Porches Carlisle, Cumbria | Woodstyle Joinery";
const description = "Handcrafted timber and oak-framed porches in Carlisle, Cumbria. Add kerb appeal, shelter, and storage to your entrance with a porch built to suit your home.";

const faqs = [
  {
    question: "Do I need planning permission for a porch?",
    answer: "Many porches fall under permitted development if they are within certain size and height limits, but it depends on your property. We can talk you through the rules and, where needed, point you in the right direction before any work starts."
  },
  {
    question: "What styles of porch do you build?",
    answer: "Everything from a simple pitched canopy over the door to fully enclosed storm porches and traditional oak-framed entrances. We match the design to your home so it looks part of the original build."
  },
  {
    question: "Can a porch really make my house warmer?",
    answer: "Yes. An enclosed porch creates a buffer between the outside and your hallway, cutting down draughts every time the front door opens and giving you a place to keep coats and boots."
  },
  {
    question: "How do I get a quote for a porch in Carlisle or Cumbria?",
    answer: "Call us on 01228 512303 or use our contact form to arrange a consultation. We will visit, take a look at your entrance, and prepare a design and quote to suit."
  }
];

const images = [
  { src: "/images/products/porches/70fe10d3-a9ca-4cbe-829d-448189e07277.jpeg", alt: "Handcrafted timber porch in Carlisle, Cumbria", caption: "Timber Porch" },
  { src: "/images/products/porches/7e3329c7-426d-4c49-9f7b-2c28ea2306d6.jpeg", alt: "Handcrafted timber porch in Carlisle, Cumbria", caption: "Oak-Framed Porch" },
  { src: "/images/products/porches/IMG_4418.jpeg", alt: "Handcrafted timber porch in Carlisle, Cumbria", caption: "Enclosed Porch" },
  { src: "/images/products/porches/IMG_4438.jpeg", alt: "Handcrafted timber porch in Carlisle, Cumbria", caption: "Pitched-Roof Porch" },
  { src: "/images/products/porches/IMG_4526.jpeg", alt: "Handcrafted timber porch in Carlisle, Cumbria", caption: "Timber Porch" },
  { src: "/images/products/porches/IMG_4547.jpeg", alt: "Handcrafted timber porch in Carlisle, Cumbria", caption: "Oak-Framed Porch" },
  { src: "/images/products/porches/IMG_5229.jpeg", alt: "Handcrafted timber porch in Carlisle, Cumbria", caption: "Enclosed Porch" },
  { src: "/images/products/porches/IMG_7861.jpeg", alt: "Handcrafted timber porch in Carlisle, Cumbria", caption: "Pitched-Roof Porch" },
  { src: "/images/products/porches/IMG_7862.jpeg", alt: "Handcrafted timber porch in Carlisle, Cumbria", caption: "Timber Porch" },
  { src: "/images/products/porches/IMG_8124.jpeg", alt: "Handcrafted timber porch in Carlisle, Cumbria", caption: "Oak-Framed Porch" },
  { src: "/images/products/porches/IMG_9751.jpeg", alt: "Handcrafted timber porch in Carlisle, Cumbria", caption: "Enclosed Porch" },
  { src: "/images/products/porches/PHOTO-2020-08-05-16-32-31.jpeg", alt: "Handcrafted timber porch in Carlisle, Cumbria", caption: "Pitched-Roof Porch" },
  { src: "/images/products/porches/b766c8c1-d6c6-4da3-a86a-2919e5c5ebf6.jpeg", alt: "Handcrafted timber porch in Carlisle, Cumbria", caption: "Timber Porch" },
  { src: "/images/products/porches/c8db9773-a1db-43d2-b8e6-9b391abaaabe.jpeg", alt: "Handcrafted timber porch in Carlisle, Cumbria", caption: "Oak-Framed Porch" },
  { src: "/images/products/porches/d68dfaba-1b08-4b84-ad7f-f37e63d2378d.jpeg", alt: "Handcrafted timber porch in Carlisle, Cumbria", caption: "Enclosed Porch" },
];
---

<ProductLayout {title} heading="Porches" {description} {images} {faqs}>
  <div class="text-xl">
    <p>From a simple pitched canopy to a fully enclosed storm porch or oak frame, we build porches that sit right against your house and look like they were always there. Give us a call on <strong>01228 512303</strong> to talk it through.</p>

    <h3 class="mt-12 mb-4">What We Offer</h3>
    <ul class="feature-list mb-2">
      <li>Open canopy, enclosed, and oak-framed porches</li>
      <li>Designs matched to your brick, render, and rooflines</li>
      <li>Shelter, storage, and a warmer entrance</li>
      <li>Solid timber and traditional joinery throughout</li>
      <li>Built to add kerb appeal and value to your home</li>
    </ul>
  </div>
</ProductLayout>
