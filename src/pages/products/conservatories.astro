---
import ProductLayout from '../../layouts/ProductLayout.astro';

const title = "Conservatories and Orangeries";
const description = "Luxury, bespoke conservatories and orangeries with classical Victorian designs and oak-framed craftsmanship to enhance your home.";

const images = [
  { src: "/images/products/conservatories/conservatory_1.jpg", alt: "Victorian style conservatory", caption: "Victorian Style Conservatory" },
  { src: "/images/products/conservatories/conservatory_2.jpg", alt: "Cox Orangery", caption: "Cox Orangery" },
  { src: "/images/products/conservatories/conservatory_3.jpg", alt: "Oak framed garden room", caption: "Oak Framed Garden Room" },
  { src: "/images/products/conservatories/conservatory_4.jpg", alt: "Luxury bespoke conservatory", caption: "Luxury Bespoke Conservatory" },
  { src: "/images/products/conservatories/conservatory_5.jpg", alt: "Classical conservatory design", caption: "Classical Conservatory Design" },
  { src: "/images/products/conservatories/conservatory_6.jpg", alt: "Garden room with hardwood finish", caption: "Garden Room with Hardwood Finish" },
  { src: "/images/products/conservatories/conservatory_7.jpg", alt: "Bespoke orangery design", caption: "Bespoke Orangery Design" },
  { src: "/images/products/conservatories/conservatory_8.jpg", alt: "Victorian conservatory extension", caption: "Victorian Conservatory Extension" },
  { src: "/images/products/conservatories/conservatory_9.jpg", alt: "Oak framed conservatory interior", caption: "Oak Framed Conservatory Interior" },
  { src: "/images/products/conservatories/conservatory_10.jpg", alt: "Luxury garden conservatory", caption: "Luxury Garden Conservatory" },
  { src: "/images/products/conservatories/conservatory_11.jpg", alt: "Classical orangery with detailing", caption: "Classical Orangery with Detailing" }
];
---

<ProductLayout {title} {description} {images}>
  <div class="fs-5">
    <p>Contemporary conservatories often have a mass-produced look, but we specialise in classical Victorian designs, utilising our hardwood skills to create something truly unique. Be the envy of your neighbourhood with a luxury, bespoke oak-framed conservatory or orangery that complements your home's architecture and lifestyle.</p>

    <p>A wooden-based design may increase the initial cost, but once varnished it reduces maintenance and greatly enhances the aesthetic quality of your home. Every project is tailored to your requirements, ensuring a bespoke result that stands out from the average conservatory or orangery.</p>

    <p>To discuss our full range of conservatories and orangeries, please contact us on <strong>01228 512303</strong> or visit our joinery showroom in Brisco, Carlisle, Cumbria.</p>

    <h3 class="mt-5">Gallery of Our Work</h3>
    <p>Here are some photos of the classical and oak-framed conservatories and orangeries we have designed and built for our customers.</p>

    <ul class="mb-4">
      <li>Classical Victorian conservatories and orangeries</li>
      <li>Luxury oak-framed garden rooms</li>
      <li>Designs that perfectly complement your home's architecture</li>
      <li>Low-maintenance, high-quality hardwood constructions</li>
      <li>Tailored solutions to suit your lifestyle and space</li>
    </ul>
  </div>
</ProductLayout>
