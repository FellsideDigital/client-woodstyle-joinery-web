---
import BaseLayout from '../../layouts/Layout.astro';

const title = "Sale Items | Woodstyle Joinery Carlisle";
const description = "Ex-display items available from our Carlisle workshop at reduced prices. Cedar garden office, oak framed gazebo, and larch Wansfell arbour.";

const email = 'joiners@woodstylejoinery.co.uk';

function mailtoUrl(subject: string, body: string): string {
  return `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
}

const cedarOfficeMailto = mailtoUrl(
  'Enquiry: Cedar Garden Office – Ex-Display Sale',
  `Hello,\n\nI'm enquiring about the following ex-display sale item listed on your website:\n\nItem: Cedar Garden Office\nSize: 3.6m x 2.6m\nFeatures: Fully Insulated, Electrics Included\nSale Price: £5,800 (was £16,800)\nLocation: Carlisle Workshop (buyer to remove)\n\nPlease could you let me know if this item is still available?\n\nKind regards,`
);

const gazeMailto = mailtoUrl(
  'Enquiry: Oak Framed Gazebo – Ex-Display Sale',
  `Hello,\n\nI'm enquiring about the following ex-display sale item listed on your website:\n\nItem: Oak Framed Gazebo with Oak Swing Seat & Cedar Roof\nSize: 2.5m x 1.7m\nSale Price: £3,800 (was £6,500)\nLocation: Carlisle Workshop\n\nPlease could you let me know if this item is still available?\n\nKind regards,`
);

const arbourMailto = mailtoUrl(
  'Enquiry: Larch Wansfell Arbour – Ex-Display Sale',
  `Hello,\n\nI'm enquiring about the following ex-display sale item listed on your website:\n\nItem: Larch "Wansfell Arbour" – Painted Green\nSale Price: £2,900 (was £3,800)\nLocation: Carlisle Workshop\n\nPlease could you let me know if this item is still available?\n\nKind regards,`
);
---

<BaseLayout title={title} description={description}>

  <!-- Hero -->
  <section class="page-hero text-center py-12 mb-12">
    <div class="container py-6" data-reveal>
      <span class="hero-eyebrow">Carlisle Workshop · Ex-Display</span>
      <h1 class="display-5 font-bold mb-4">Sale Items</h1>
      <p class="lead mx-auto mb-0" style="max-width: 600px">
        Ex-display pieces available directly from our Carlisle workshop at significantly reduced prices.
      </p>
    </div>
  </section>

  <!-- Featured sale item -->
  <section class="section bg-white">
    <div class="container">
      <div class="text-center mb-12" data-reveal>
        <span class="section-kicker">Available Now</span>
        <h2 class="font-bold text-primary-custom heading-accent">For Sale</h2>
      </div>

      <div class="featured-item" data-reveal>

        <div class="featured-img">
          <img
            src="/images/products/sale-items/garden-office.jpeg"
            alt="Cedar garden office, ex-display at Woodstyle Joinery, Carlisle"
            loading="eager"
          />
          <div class="featured-badge">Ex-Display</div>
        </div>

        <div class="featured-body">
          <h3 class="featured-name">Cedar Garden Office</h3>

          <div class="featured-meta">
            <div class="meta-chip">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Carlisle Workshop
            </div>
            <div class="meta-chip">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="3"/></svg>
              3.6m × 2.6m
            </div>
            <div class="meta-chip">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
              Fully Insulated
            </div>
            <div class="meta-chip">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              Electrics Included
            </div>
          </div>

          <div class="featured-pricing">
            <div class="pricing-inner">
              <span class="price-label">Was</span>
              <span class="price-was">£16,800</span>
            </div>
            <div class="pricing-divider"></div>
            <div class="pricing-inner">
              <span class="price-label">Now: Ex-Display</span>
              <span class="price-now">£5,800</span>
            </div>
          </div>

          <p class="buyer-note">Buyer to remove from our Carlisle workshop.</p>

          <a href={cedarOfficeMailto} class="btn btn-secondary-custom btn-lg">Enquire About This Item</a>
        </div>

      </div>

      <hr class="item-divider" />

      <div class="featured-item featured-item--reverse" data-reveal>

        <div class="featured-img">
          <img
            src="/images/products/sale-items/gazebo.jpeg"
            alt="Oak framed gazebo with swing seat and cedar roof, ex-display at Woodstyle Joinery, Carlisle"
            loading="lazy"
          />
          <div class="featured-badge">Ex-Display</div>
        </div>

        <div class="featured-body">
          <h3 class="featured-name">Oak Framed Gazebo with Oak Swing Seat & Cedar Roof</h3>

          <div class="featured-meta">
            <div class="meta-chip">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Carlisle Workshop
            </div>
            <div class="meta-chip">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="3"/></svg>
              2.5m × 1.7m
            </div>
          </div>

          <div class="featured-pricing">
            <div class="pricing-inner">
              <span class="price-label">Was</span>
              <span class="price-was">£6,500</span>
            </div>
            <div class="pricing-divider"></div>
            <div class="pricing-inner">
              <span class="price-label">Now: Ex-Display</span>
              <span class="price-now">£3,800</span>
            </div>
          </div>

          <p class="buyer-note">&nbsp;</p>

          <a href={gazeMailto} class="btn btn-secondary-custom btn-lg">Enquire About This Item</a>
        </div>

      </div>

      <hr class="item-divider" />

      <div class="featured-item" data-reveal>

        <div class="featured-img">
          <img
            src="/images/products/sale-items/wansfell-arbour.jpeg"
            alt="Larch Wansfell Arbour painted green, ex-display at Woodstyle Joinery, Carlisle"
            loading="lazy"
          />
          <div class="featured-badge">Ex-Display</div>
        </div>

        <div class="featured-body">
          <h3 class="featured-name">Larch "Wansfell Arbour", Painted Green</h3>

          <div class="featured-meta">
            <div class="meta-chip">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Carlisle Workshop
            </div>
          </div>

          <div class="featured-pricing">
            <div class="pricing-inner">
              <span class="price-label">Was</span>
              <span class="price-was">£3,800</span>
            </div>
            <div class="pricing-divider"></div>
            <div class="pricing-inner">
              <span class="price-label">Now: Ex-Display</span>
              <span class="price-now">£2,900</span>
            </div>
          </div>

          <p class="buyer-note">Contact the workshop for details.</p>

          <a href={arbourMailto} class="btn btn-secondary-custom btn-lg">Enquire About This Item</a>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-cream-deep text-center section">
    <div class="container" data-reveal>
      <h2 class="font-bold text-primary-custom mb-4">Interested? Get In Touch Today</h2>
      <p class="lead mx-auto mb-6" style="max-width: 520px">
        Call us on <strong>01228 512303</strong> or use our contact form and we'll get back to you promptly.
      </p>
      <a href="/contact" class="btn btn-secondary-custom btn-lg font-bold">Contact Us</a>
    </div>
  </section>

</BaseLayout>

<style>
.featured-item {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3.5rem;
  align-items: start;
  max-width: 1060px;
  margin-inline: auto;
}
@media (max-width: 768px) {
  .featured-item {
    grid-template-columns: 1fr;
    gap: 2rem;
  }
}

.featured-img {
  position: relative;
  border-radius: var(--radius-md);
  overflow: hidden;
  aspect-ratio: 4 / 3;
  box-shadow: var(--shadow-md);
}
.featured-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.featured-badge {
  position: absolute;
  top: 1.1rem;
  left: 1.1rem;
  background: var(--accent);
  color: #fff;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  padding: 0.35rem 0.8rem;
  border-radius: var(--radius-pill);
}

.featured-body {
  display: flex;
  flex-direction: column;
}

.featured-name {
  font-size: 1.9rem;
  margin-bottom: 1rem;
  line-height: 1.15;
}

.featured-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 1.4rem;
}

.meta-chip {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--ink-muted);
  background: var(--cream-deep);
  border: 1px solid var(--border);
  border-radius: var(--radius-pill);
  padding: 0.3rem 0.75rem;
}
.meta-chip svg {
  flex-shrink: 0;
  color: var(--primary);
}

.featured-description {
  color: var(--ink-muted);
  font-size: 0.98rem;
  line-height: 1.7;
  margin-bottom: 1.25rem;
}

.featured-pricing {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  background: var(--cream-deep);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 1.25rem 1.5rem;
  margin-bottom: 0.85rem;
}

.pricing-inner {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}

.price-label {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-muted);
}

.price-was {
  font-family: var(--font-heading);
  font-size: 1.5rem;
  font-weight: 600;
  color: var(--ink-muted);
  text-decoration: line-through;
}

.price-now {
  font-family: var(--font-heading);
  font-size: 2.4rem;
  font-weight: 600;
  color: var(--accent-dark);
  line-height: 1;
}

.pricing-divider {
  width: 1px;
  height: 48px;
  background: var(--border-strong);
  flex-shrink: 0;
}

.item-divider {
  border: none;
  border-top: 1px solid var(--border);
  margin: 4rem auto;
  max-width: 1060px;
}

.featured-item--reverse {
  direction: rtl;
}
.featured-item--reverse > * {
  direction: ltr;
}

.buyer-note {
  font-size: 0.85rem;
  color: var(--ink-muted);
  margin-bottom: 1.5rem;
}
</style>
