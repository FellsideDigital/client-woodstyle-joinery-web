---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const {
  title = "Woodstyle Joinery | Bespoke Joinery Carlisle, Cumbria",
  description = "Bespoke joinery and woodwork crafted for Cumbrian homes since 1988. Kitchens, bedrooms, conservatories, garages and more. Call 01228 512303.",
  ogImage = "/images/home-image.png",
} = Astro.props;

const siteUrl = 'https://www.woodstylejoinery.co.uk';
const canonicalURL = new URL(Astro.url.pathname, siteUrl).href;
const ogImageURL = new URL(ogImage, siteUrl).href;

const schema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "GeneralContractor"],
  "name": "Woodstyle Joinery",
  "description": "Bespoke joinery and woodwork handcrafted in Cumbria since 1988.",
  "url": siteUrl,
  "telephone": "+441228512303",
  "email": "info@woodstylejoinery.co.uk",
  "foundingDate": "1988",
  "priceRange": "££–££££",
  "image": `${siteUrl}/images/site-logo.png`,
  "logo": `${siteUrl}/images/site-logo.png`,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Wood Bank Farm, Brisco",
    "addressLocality": "Carlisle",
    "addressRegion": "Cumbria",
    "postalCode": "CA4 0QP",
    "addressCountry": "GB"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 54.8673699,
    "longitude": -2.9058588
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "09:00",
      "closes": "17:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "10:00",
      "closes": "14:00"
    }
  ],
  "areaServed": [
    { "@type": "City", "name": "Carlisle" },
    { "@type": "AdministrativeArea", "name": "Cumbria" }
  ]
};
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Woodstyle Joinery" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:alt" content="Woodstyle Joinery — bespoke woodwork in Carlisle, Cumbria" />
    <meta property="og:locale" content="en_GB" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <!-- Styles -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://unpkg.com/feather-icons"></script>
    <link rel="stylesheet" href="/styles/main.css" />
  </head>
  <body class="bg-light text-dark">
    <Header />
    <main><slot /></main>
    <Footer />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        if (window.feather) feather.replace();
      });
    </script>
  </body>
</html>
