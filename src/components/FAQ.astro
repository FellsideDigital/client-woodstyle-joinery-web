---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
  title?: string;
  uid?: string;
}

const { items, title = "Frequently Asked Questions", uid = "faq" } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": items.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
---

<section class="section bg-light">
  <div class="container py-4">
    <div class="mb-12 text-center" data-reveal>
      <span class="section-kicker">Good To Know</span>
      <h2 class="font-bold text-primary-custom heading-accent">{title}</h2>
    </div>
    <div class="mx-auto max-w-[820px] space-y-2" data-reveal>
      {items.map((item, i) => (
        <details class="faq-item" open={i === 0}>
          <summary class="faq-summary">{item.question}</summary>
          <div class="faq-body">{item.answer}</div>
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

<style>
  .faq-item {
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
  }
  .faq-summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.15rem 1.35rem;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.08rem;
    color: var(--ink);
    transition: color 0.2s var(--ease), background-color 0.2s var(--ease);
  }
  .faq-summary::-webkit-details-marker { display: none; }
  .faq-summary::after {
    content: "";
    width: 0.62rem;
    height: 0.62rem;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: rotate(45deg);
    transition: transform 0.25s var(--ease);
    flex-shrink: 0;
    opacity: 0.7;
  }
  .faq-item[open] .faq-summary {
    color: var(--primary);
    background-color: rgba(85, 105, 86, 0.06);
  }
  .faq-item[open] .faq-summary::after { transform: rotate(225deg); }
  .faq-summary:focus-visible {
    outline: none;
    box-shadow: inset 0 0 0 3px rgba(85, 105, 86, 0.25);
  }
  .faq-body {
    padding: 0.25rem 1.35rem 1.2rem;
    color: var(--ink-muted);
    line-height: 1.7;
  }
</style>
