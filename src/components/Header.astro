---
// src/components/Header.astro
const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
const links = [
  { href: '/', label: 'Home' },
  { href: '/products', label: 'Products' },
  { href: '/design', label: 'Design Service' },
  { href: '/about', label: 'About' },
  { href: '/testimonials', label: 'Testimonials' },
  { href: '/contact', label: 'Contact' },
];
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---
<nav class="navbar navbar-expand-lg navbar-light sticky-top header-navbar">
  <div class="container">
    <!-- Logo -->
    <a class="navbar-brand" href="/">
      <img src="/images/site-logo.png" alt="Woodstyle Joinery Logo" height="60" class="logo-img" />
    </a>

    <!-- Hamburger -->
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Navigation Links -->
    <div class="collapse navbar-collapse" id="mainNav">
      <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-3">
        {links.map((link) => (
          <li class="nav-item">
            <a
              class={`nav-link ${isActive(link.href) ? 'active' : ''}`}
              href={link.href}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >{link.label}</a>
          </li>
        ))}
        <li class="nav-item">
          <a class="btn btn-quote px-4 fw-semibold" href="/contact">Get a Quote</a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<style>
/* ===================== */
/* Navbar Container      */
/* ===================== */
.header-navbar {
  background: var(--surface, #fff);
  padding: 0.65rem 1rem;
  border-bottom: 1px solid var(--border, #e4e0d4);
  box-shadow: 0 1px 0 rgba(43, 51, 40, 0.02);
  z-index: 999;
}

/* ===================== */
/* Logo Styling          */
/* ===================== */
.logo-img {
  transition: transform 0.3s var(--ease, ease);
}
.logo-img:hover {
  transform: scale(1.04);
}

/* ===================== */
/* Navbar Links          */
/* ===================== */
.navbar-nav .nav-link {
  color: var(--ink, #2b3328);
  font-weight: 500;
  font-size: 0.95rem;
  position: relative;
  padding-block: 0.4rem;
  transition: color 0.25s var(--ease, ease);
}
.navbar-nav .nav-link::after {
  content: "";
  display: block;
  width: 0%;
  height: 2px;
  border-radius: 2px;
  background: var(--accent, #a87c4f);
  transition: width 0.25s var(--ease, ease);
  position: absolute;
  bottom: 0;
  left: 0;
}
.navbar-nav .nav-link:hover,
.navbar-nav .nav-link:focus-visible,
.navbar-nav .nav-link.active {
  color: var(--primary, #556956);
}
.navbar-nav .nav-link:hover::after,
.navbar-nav .nav-link:focus-visible::after,
.navbar-nav .nav-link.active::after {
  width: 100%;
}
.navbar-nav .nav-link.active {
  font-weight: 600;
}

/* ===================== */
/* Quote Button          */
/* ===================== */
.btn-quote {
  background: var(--primary, #556956);
  color: #fff;
  border-radius: 8px;
  font-weight: 600;
  letter-spacing: 0.01em;
  transition: transform 0.25s var(--ease, ease), box-shadow 0.25s var(--ease, ease), background 0.25s var(--ease, ease);
}
.btn-quote:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 24px rgba(85, 105, 86, 0.3);
  background: var(--primary-dark, #3d4d3e);
  color: #fff;
}

/* ===================== */
/* Responsive tweaks     */
/* ===================== */
@media (max-width: 991px) {
  .navbar-nav {
    gap: 0.5rem;
    padding-top: 0.5rem;
  }
  .navbar-nav .nav-link::after {
    display: none;
  }
  .btn-quote {
    width: 100%;
    text-align: center;
    margin-top: 0.5rem;
  }
}
</style>
