---
// src/components/Header.astro
const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
const links = [
  { href: '/', label: 'Home' },
  { href: '/products', label: 'Products' },
  { href: '/design', label: 'Design Service' },
  { href: '/about', label: 'About' },
  { href: '/testimonials', label: 'Testimonials' },
  { href: '/contact', label: 'Contact' },
];
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---
<header class="site-header">
  <!-- Utility strip -->
  <div class="topbar">
    <div class="container topbar-inner">
      <p class="topbar-tagline">Bespoke joinery, handcrafted in Cumbria since 1988</p>
      <div class="topbar-meta">
        <a class="topbar-phone" href="tel:01228512303">
          <i data-feather="phone" aria-hidden="true"></i>
          <span>01228&nbsp;512303</span>
        </a>
        <span class="topbar-divider" aria-hidden="true"></span>
        <span class="topbar-hours">Mon–Fri 9–5 &middot; Sat 8–12</span>
      </div>
    </div>
  </div>

  <!-- Main bar -->
  <nav class="header-navbar sticky top-0">
    <div class="container nav-inner">
      <!-- Logo -->
      <a class="nav-logo shrink-0" href="/" aria-label="Woodstyle Joinery home">
        <img src="/images/site-logo.png" alt="Woodstyle Joinery" class="logo-img" />
      </a>

      <!-- Hamburger -->
      <button
        type="button"
        id="nav-toggle"
        class="nav-toggle"
        aria-controls="mainNav"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <i data-feather="menu" class="icon-menu" aria-hidden="true"></i>
        <i data-feather="x" class="icon-close" aria-hidden="true"></i>
      </button>

      <!-- Navigation -->
      <div class="nav-menu" id="mainNav">
        <ul class="navbar-nav">
          {links.map((link) => (
            <li>
              <a
                class={`nav-link ${isActive(link.href) ? 'active' : ''}`}
                href={link.href}
                aria-current={isActive(link.href) ? 'page' : undefined}
              >{link.label}</a>
            </li>
          ))}
        </ul>

        <div class="nav-actions">
          <a class="nav-phone" href="tel:01228512303">
            <i data-feather="phone" aria-hidden="true"></i>
            <span>01228 512303</span>
          </a>
          <a class="btn btn-quote" href="/contact">Get a Free Quote</a>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  const header = document.querySelector('.header-navbar');
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mainNav');

  // Condense the bar once the page has scrolled a touch.
  const onScroll = () => header?.classList.toggle('scrolled', window.scrollY > 8);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // Mobile menu open/close.
  const setOpen = (open: boolean) => {
    menu?.classList.toggle('open', open);
    toggle?.classList.toggle('is-open', open);
    toggle?.setAttribute('aria-expanded', String(open));
  };
  toggle?.addEventListener('click', () =>
    setOpen(!menu?.classList.contains('open'))
  );
  menu?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => setOpen(false))
  );
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setOpen(false);
  });
  window.addEventListener('resize', () => {
    if (window.innerWidth >= 1024) setOpen(false);
  });
</script>

<style>
/* ===================== */
/* Utility strip          */
/* ===================== */
.topbar {
  background: var(--primary-darker, #2f3b30);
  color: rgba(255, 255, 255, 0.78);
  font-size: 0.82rem;
  border-top: 3px solid var(--accent, #a87c4f); /* bookends the footer's accent rule */
}
.topbar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  min-height: 40px;
}
.topbar-tagline {
  margin: 0;
  letter-spacing: 0.01em;
}
.topbar-meta {
  display: flex;
  align-items: center;
  gap: 0.85rem;
  white-space: nowrap;
}
.topbar-phone {
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  color: #fff;
  font-weight: 600;
  text-decoration: none;
  transition: color 0.2s var(--ease, ease);
}
.topbar-phone svg {
  width: 15px;
  height: 15px;
  stroke: var(--accent-soft, #c79a6a);
}
.topbar-phone:hover { color: var(--accent-soft, #c79a6a); }
.topbar-divider {
  width: 1px;
  height: 14px;
  background: rgba(255, 255, 255, 0.22);
}
.topbar-hours { letter-spacing: 0.02em; }

@media (max-width: 1023.98px) {
  .topbar-tagline,
  .topbar-divider,
  .topbar-hours { display: none; }
  .topbar-inner { justify-content: center; }
}

/* ===================== */
/* Main bar               */
/* ===================== */
.header-navbar {
  background: var(--surface, #fff);
  border-bottom: 1px solid var(--border, #e4e0d4);
  z-index: 999;
  transition: box-shadow 0.3s var(--ease, ease), padding 0.3s var(--ease, ease);
}
.header-navbar.scrolled {
  box-shadow: 0 6px 24px rgba(43, 51, 40, 0.08);
}
.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.5rem;
  padding-block: 0.85rem;
  transition: padding 0.3s var(--ease, ease);
}
.header-navbar.scrolled .nav-inner { padding-block: 0.5rem; }

/* Logo */
.logo-img {
  display: block;
  height: 58px;
  width: auto;
  transition: height 0.3s var(--ease, ease), transform 0.3s var(--ease, ease);
}
.header-navbar.scrolled .logo-img { height: 48px; }
.nav-logo:hover .logo-img { transform: scale(1.03); }

/* Menu wrapper */
.nav-menu {
  display: flex;
  align-items: center;
  gap: 2rem;
}
.navbar-nav {
  display: flex;
  align-items: center;
  gap: 1.6rem;
  list-style: none;
  margin: 0;
  padding: 0;
}

/* Links */
.nav-link {
  color: var(--ink, #2b3328);
  font-weight: 500;
  font-size: 0.95rem;
  text-decoration: none;
  position: relative;
  padding-block: 0.35rem;
  transition: color 0.25s var(--ease, ease);
}
.nav-link::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: -2px;
  width: 0;
  height: 2px;
  border-radius: 2px;
  background: var(--accent, #a87c4f);
  transition: width 0.25s var(--ease, ease);
}
.nav-link:hover,
.nav-link:focus-visible,
.nav-link.active { color: var(--primary, #556956); }
.nav-link:hover::after,
.nav-link:focus-visible::after,
.nav-link.active::after { width: 100%; }
.nav-link.active { font-weight: 600; }

/* Right-hand actions */
.nav-actions {
  display: flex;
  align-items: center;
  gap: 1.1rem;
}
.nav-phone {
  display: none; /* topbar carries the phone on desktop */
}
.btn-quote {
  background: var(--accent, #a87c4f);
  border: 1px solid var(--accent, #a87c4f);
  color: #fff;
  border-radius: var(--radius-sm, 8px);
  font-weight: 600;
  letter-spacing: 0.01em;
  box-shadow: var(--shadow-xs);
}
.btn-quote:hover,
.btn-quote:focus-visible {
  background: var(--accent-dark, #8c6539);
  border-color: var(--accent-dark, #8c6539);
  color: #fff;
  transform: translateY(-2px);
  box-shadow: var(--shadow-accent);
}

/* Hamburger */
.nav-toggle {
  display: none;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  border: 1px solid var(--border, #e4e0d4);
  border-radius: var(--radius-sm, 8px);
  background: var(--cream, #f8f6f0);
  color: var(--ink, #2b3328);
  cursor: pointer;
  transition: background 0.2s var(--ease, ease), border-color 0.2s var(--ease, ease);
}
.nav-toggle:hover { border-color: var(--border-strong, #d6d0bf); }
.nav-toggle svg { width: 22px; height: 22px; }
.nav-toggle .icon-close { display: none; }
.nav-toggle.is-open .icon-menu { display: none; }
.nav-toggle.is-open .icon-close { display: block; }

/* ===================== */
/* Mobile layout          */
/* ===================== */
@media (max-width: 1023.98px) {
  .nav-toggle { display: inline-flex; }

  .nav-menu {
    position: absolute;
    left: 0;
    right: 0;
    top: 100%;
    flex-direction: column;
    align-items: stretch;
    gap: 0;
    padding: 0.5rem 1rem 1.25rem;
    background: var(--surface, #fff);
    border-bottom: 1px solid var(--border, #e4e0d4);
    box-shadow: 0 18px 40px rgba(43, 51, 40, 0.12);
    opacity: 0;
    transform: translateY(-10px);
    pointer-events: none;
    transition: opacity 0.25s var(--ease, ease), transform 0.25s var(--ease, ease);
  }
  .nav-menu.open {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .header-navbar { position: sticky; } /* anchor for the absolute panel */
  .nav-inner { position: relative; }

  .navbar-nav {
    flex-direction: column;
    align-items: stretch;
    gap: 0;
    width: 100%;
  }
  .navbar-nav li { border-bottom: 1px solid var(--border, #e4e0d4); }
  .nav-link {
    display: block;
    padding: 0.9rem 0.25rem;
    font-size: 1.02rem;
  }
  .nav-link::after { display: none; }
  .nav-link.active {
    color: var(--primary, #556956);
    padding-left: 0.85rem;
    border-left: 3px solid var(--accent, #a87c4f);
  }

  .nav-actions {
    flex-direction: column;
    align-items: stretch;
    gap: 0.75rem;
    margin-top: 1.1rem;
  }
  .nav-phone {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--border-strong, #d6d0bf);
    border-radius: var(--radius-sm, 8px);
    color: var(--primary-dark, #3d4d3e);
    font-weight: 600;
    text-decoration: none;
  }
  .nav-phone svg { width: 18px; height: 18px; stroke: var(--accent, #a87c4f); }
  .btn-quote { width: 100%; padding-block: 0.8rem; }
}
</style>
