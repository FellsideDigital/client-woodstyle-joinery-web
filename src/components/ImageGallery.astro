---
const { images } = Astro.props; // [{ src, thumb?, alt }]
---

<!-- Swiper CSS -->
<link
  rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/Swiper/6.6.1/swiper-bundle.min.css"
/>

<div class="gallery" data-count={images.length}>
  <!-- Main slider -->
  <div class="swiper-container gallery-slider">
    <div class="swiper-wrapper">
      {images.map(img => (
        <div class="swiper-slide">
          <img src={img.src} alt={img.alt || ""} />
        </div>
      ))}
    </div>
    <div class="swiper-button-prev"></div>
    <div class="swiper-button-next"></div>
  </div>

  <!-- Thumbnail slider -->
  <div class="swiper-container gallery-thumbs">
    <div class="swiper-wrapper">
      {images.map(img => (
        <div class="swiper-slide">
          <img src={img.thumb || img.src} alt={img.alt || ""} />
        </div>
      ))}
    </div>
  </div>
</div>

<style>
/* ---------------------- */
/* General Styles */
/* ---------------------- */
body {
  background-color: #fff;
  font-family: sans-serif;
  margin: 0;
  padding: 0;
}

.gallery {
  width: 100%;
  max-width: 640px;
  margin: 30px auto;
}

/* ---------------------- */
/* Main Slider */
/* ---------------------- */
.gallery-slider {
  width: 100%;
  height: 420px;
  margin-bottom: 10px;
}

.gallery-slider .swiper-slide {
  display: flex;
  align-items: center;
  justify-content: center;
}

.gallery-slider .swiper-slide img {
  width: auto;
  max-width: 100%;
  height: 100%;
  object-fit: contain;
  border-radius: 4px;
  user-select: none;
  -webkit-user-drag: none;
  -moz-user-select: none;
  -ms-user-select: none;
  pointer-events: none;
}

/* ---------------------- */
/* Thumbnails */
/* ---------------------- */
.gallery-thumbs {
  width: 100%;
  height: 100px;
  box-sizing: border-box;
  margin-top: 5px;
}

.gallery-thumbs .swiper-slide {
  width: 80px;
  height: 80px;
  opacity: 0.4;
  cursor: pointer;
  transition: opacity 0.2s;
}

.gallery-thumbs .swiper-slide-active {
  opacity: 1;
}

.gallery-thumbs .swiper-slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 4px;
  user-select: none;
  -webkit-user-drag: none;
  -moz-user-select: none;
  -ms-user-select: none;
  pointer-events: none;
}

/* ---------------------- */
/* Navigation Arrows */
/* ---------------------- */
.swiper-button-prev,
.swiper-button-next {
  color: #aaa;              /* light gray */
  font-size: 1.8rem;        /* thick arrows */
  font-weight: 700;         
  padding: 0.2rem 1.3rem;
  border-radius: 4px;       
  background: transparent;  
  box-shadow: none;         
  top: 50%;
  transform: translateY(-50%);
  transition: color 0.2s, transform 0.2s;
}

/* Push arrows slightly outside the gallery */
.swiper-button-prev { left: -9px; }
.swiper-button-next { right: -9px; }

.swiper-button-prev:hover,
.swiper-button-next:hover {
  color: #777;               
  transform: translateY(-50%) scale(1.05); 
}
</style>

<!-- Swiper JS -->
<script type="module" src="https://cdnjs.cloudflare.com/ajax/libs/Swiper/6.6.1/swiper-bundle.esm.browser.min.js"></script>

<script type="module">
import Swiper from 'https://cdnjs.cloudflare.com/ajax/libs/Swiper/6.6.1/swiper-bundle.esm.browser.min.js';

const gallery = document.querySelector(".gallery");
const slideCount = parseInt(gallery.dataset.count, 10);

/* Thumbnail slider */
const thumbs = new Swiper(".gallery-thumbs", {
  slidesPerView: "auto",
  spaceBetween: 10,
  centeredSlides: true,
  loop: true,
  slideToClickedSlide: true,
});

/* Main slider */
const slider = new Swiper(".gallery-slider", {
  slidesPerView: 1,
  centeredSlides: true,
  loop: true,
  loopedSlides: slideCount,
  navigation: {
    nextEl: ".swiper-button-next",
    prevEl: ".swiper-button-prev",
  },
  controller: { control: thumbs },
});

/* Connect thumbs to main slider */
thumbs.controller.control = slider;
</script>
