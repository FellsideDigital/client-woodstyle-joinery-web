---
const { images } = Astro.props; // [{ src, thumb?, alt }]
---

<!-- Swiper CSS -->
<link
  rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/Swiper/6.6.1/swiper-bundle.min.css"
/>

<div class="gallery" data-count={images.length}>
  <!-- Main slider -->
  <div class="swiper-container gallery-slider">
    <div class="swiper-wrapper">
      {images.map(img => (
        <div class="swiper-slide">
          <img src={img.src} alt={img.alt || ""} />
        </div>
      ))}
    </div>
    <div class="swiper-button-prev"></div>
    <div class="swiper-button-next"></div>
  </div>

  <!-- Thumbnail slider -->
  <div class="swiper-container gallery-thumbs">
    <div class="swiper-wrapper">
      {images.map(img => (
        <div class="swiper-slide">
          <img src={img.thumb || img.src} alt={img.alt || ""} />
        </div>
      ))}
    </div>
  </div>
</div>

<style>
/* ---------------------- */
/* General Styles */
/* ---------------------- */
.gallery {
  width: 100%;
  max-width: 640px;
  margin: 30px auto;
}

/* ---------------------- */
/* Main Slider */
/* ---------------------- */
.gallery-slider {
  width: 100%;
  height: 420px;
  margin-bottom: 10px;
}

.gallery-slider .swiper-slide {
  display: flex;
  align-items: center;
  justify-content: center;
}

.gallery-slider .swiper-slide img {
  width: auto;
  max-width: 100%;
  height: 100%;
  object-fit: contain;
  border-radius: var(--radius-md, 14px);
  box-shadow: var(--shadow-sm, 0 2px 16px rgba(43, 51, 40, 0.07));
  user-select: none;
  -webkit-user-drag: none;
  -moz-user-select: none;
  -ms-user-select: none;
  pointer-events: none;
}

/* ---------------------- */
/* Thumbnails */
/* ---------------------- */
.gallery-thumbs {
  width: 100%;
  height: 100px;
  box-sizing: border-box;
  margin-top: 5px;
}

.gallery-thumbs .swiper-slide {
  width: 80px;
  height: 80px;
  opacity: 0.45;
  cursor: pointer;
  border-radius: var(--radius-sm, 8px);
  transition: opacity 0.25s, box-shadow 0.25s, transform 0.25s;
}

.gallery-thumbs .swiper-slide:hover {
  opacity: 0.8;
}

.gallery-thumbs .swiper-slide-active {
  opacity: 1;
  box-shadow: 0 0 0 2px var(--accent, #a87c4f);
}

.gallery-thumbs .swiper-slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: var(--radius-sm, 8px);
  user-select: none;
  -webkit-user-drag: none;
  -moz-user-select: none;
  -ms-user-select: none;
  pointer-events: none;
}

/* ---------------------- */
/* Navigation Arrows */
/* ---------------------- */
.swiper-button-prev,
.swiper-button-next {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: var(--surface, #fff);
  color: var(--primary, #556956);
  box-shadow: var(--shadow-sm, 0 2px 16px rgba(43, 51, 40, 0.07));
  top: 50%;
  transform: translateY(-50%);
  transition: color 0.2s, background 0.2s, transform 0.2s, box-shadow 0.2s;
}
.swiper-button-prev::after,
.swiper-button-next::after {
  font-size: 1.1rem;
  font-weight: 700;
}

/* Push arrows slightly outside the gallery */
.swiper-button-prev { left: -14px; }
.swiper-button-next { right: -14px; }

.swiper-button-prev:hover,
.swiper-button-next:hover {
  color: #fff;
  background: var(--primary, #556956);
  box-shadow: var(--shadow-md, 0 16px 40px rgba(43, 51, 40, 0.1));
  transform: translateY(-50%) scale(1.06);
}
</style>

<!-- Swiper JS -->
<script type="module" src="https://cdnjs.cloudflare.com/ajax/libs/Swiper/6.6.1/swiper-bundle.esm.browser.min.js"></script>

<script type="module">
import Swiper from 'https://cdnjs.cloudflare.com/ajax/libs/Swiper/6.6.1/swiper-bundle.esm.browser.min.js';

const gallery = document.querySelector(".gallery");
const slideCount = parseInt(gallery.dataset.count, 10);

/* Thumbnail slider */
const thumbs = new Swiper(".gallery-thumbs", {
  slidesPerView: "auto",
  spaceBetween: 10,
  centeredSlides: true,
  loop: true,
  slideToClickedSlide: true,
});

/* Main slider */
const slider = new Swiper(".gallery-slider", {
  slidesPerView: 1,
  centeredSlides: true,
  loop: true,
  loopedSlides: slideCount,
  navigation: {
    nextEl: ".swiper-button-next",
    prevEl: ".swiper-button-prev",
  },
  controller: { control: thumbs },
});

/* Connect thumbs to main slider */
thumbs.controller.control = slider;
</script>
