---
const { images } = Astro.props;
const count = images.length;
---

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<div class="ig-root" data-count={count}>

  <!-- Main slider -->
  <div class="ig-main">
    <div class="swiper ig-swiper">
      <div class="swiper-wrapper">
        {images.map((img, i) => (
          <div class="swiper-slide" data-index={i} data-src={img.src} data-alt={img.alt || ""} data-caption={img.caption || ""}>
            <button class="ig-open-btn" aria-label="View full size" type="button">
              <img src={img.src} alt={img.alt || ""} loading="lazy" />
              <span class="ig-zoom-hint" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
              </span>
            </button>
          </div>
        ))}
      </div>
      <button class="swiper-button-prev ig-nav" aria-label="Previous image"></button>
      <button class="swiper-button-next ig-nav" aria-label="Next image"></button>
      <div class="ig-counter"><span class="ig-cur">1</span>&thinsp;/&thinsp;<span class="ig-tot">{count}</span></div>
    </div>
  </div>

  <!-- Thumbnails -->
  <div class="swiper ig-thumbs-swiper">
    <div class="swiper-wrapper">
      {images.map(img => (
        <div class="swiper-slide">
          <img src={img.thumb || img.src} alt={img.alt || ""} loading="lazy" />
        </div>
      ))}
    </div>
  </div>
</div>

<!-- Lightbox -->
<div class="ig-lb" id="ig-lightbox" role="dialog" aria-modal="true" aria-label="Full-size image viewer" hidden>
  <div class="ig-lb-backdrop"></div>
  <button class="ig-lb-close" aria-label="Close viewer" type="button">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  <button class="ig-lb-prev" aria-label="Previous" type="button">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
  </button>
  <button class="ig-lb-next" aria-label="Next" type="button">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
  </button>
  <div class="ig-lb-wrap">
    <img src="" alt="" class="ig-lb-img" />
  </div>
  <div class="ig-lb-footer">
    <p class="ig-lb-caption"></p>
    <p class="ig-lb-counter"></p>
  </div>
</div>

<style>
/* ── Root ────────────────────────────────────────────── */
.ig-root {
  width: 100%;
  max-width: 1100px;
  margin: 2rem auto 0;
}

/* ── Main slider ─────────────────────────────────────── */
.ig-main {
  position: relative;
  border-radius: var(--radius-lg, 24px);
  overflow: hidden;
  background: #16191b;
  box-shadow: var(--shadow-lg, 0 30px 70px rgba(43,51,40,0.16));
}

.ig-swiper {
  width: 100%;
  height: clamp(400px, 70vh, 900px);
}

.ig-swiper .swiper-slide {
  position: relative;
  display: flex;
  flex-direction: column;
}

/* Clickable image button */
.ig-open-btn {
  flex: 1;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  background: #d4d4d4;
  border: none;
  padding: 0;
  margin: 0;
  cursor: zoom-in;
  overflow: hidden;
  outline: none;
}

.ig-open-btn img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: center;
  display: block;
  user-select: none;
  -webkit-user-drag: none;
}

/* Zoom hint icon */
.ig-zoom-hint {
  position: absolute;
  top: 1rem;
  right: 1rem;
  background: rgba(0, 0, 0, 0.45);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  color: #fff;
  border-radius: 50%;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transform: scale(0.8);
  transition: opacity 0.2s, transform 0.2s;
  border: 1px solid rgba(255,255,255,0.2);
}

.ig-open-btn:hover .ig-zoom-hint {
  opacity: 1;
  transform: scale(1);
}

/* Caption overlay */
.ig-caption {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  margin: 0;
  padding: 2.5rem 1.5rem 1.1rem;
  background: linear-gradient(to top, rgba(0,0,0,0.62) 0%, transparent 100%);
  color: rgba(255, 255, 255, 0.9);
  font-size: 0.85rem;
  font-weight: 500;
  letter-spacing: 0.03em;
  text-align: center;
  pointer-events: none;
}

/* Slide counter badge */
.ig-counter {
  position: absolute;
  top: 1rem;
  left: 1rem;
  z-index: 10;
  background: rgba(0, 0, 0, 0.45);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  color: rgba(255,255,255,0.9);
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  border-radius: 20px;
  padding: 0.3rem 0.8rem;
  border: 1px solid rgba(255,255,255,0.15);
  pointer-events: none;
  user-select: none;
}

/* Navigation arrows */
.swiper-button-prev.ig-nav,
.swiper-button-next.ig-nav {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.13);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1.5px solid rgba(255, 255, 255, 0.22);
  color: #fff;
  margin-top: -25px;
  transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
}

.swiper-button-prev.ig-nav::after,
.swiper-button-next.ig-nav::after {
  font-size: 1rem;
  font-weight: 800;
}

.swiper-button-prev.ig-nav:hover,
.swiper-button-next.ig-nav:hover {
  background: rgba(255, 255, 255, 0.26);
  box-shadow: 0 4px 20px rgba(0,0,0,0.3);
}

/* ── Thumbnails ──────────────────────────────────────── */
.ig-thumbs-swiper {
  margin-top: 0.65rem;
  height: 116px;
  padding: 4px 2px;
}

.ig-thumbs-swiper .swiper-slide {
  width: 108px !important;
  height: 100px;
  border-radius: var(--radius-sm, 8px);
  overflow: hidden;
  opacity: 0.45;
  cursor: pointer;
  border: 2px solid transparent;
  transition: opacity 0.22s, transform 0.22s, border-color 0.22s, box-shadow 0.22s;
  flex-shrink: 0;
}

.ig-thumbs-swiper .swiper-slide:hover {
  opacity: 0.78;
}

.ig-thumbs-swiper .swiper-slide-thumb-active {
  opacity: 1;
  border-color: var(--accent, #a87c4f);
  box-shadow: 0 0 0 1px var(--accent, #a87c4f);
  transform: scale(1.04);
}

.ig-thumbs-swiper .swiper-slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  pointer-events: none;
  user-select: none;
  -webkit-user-drag: none;
}

/* ── Lightbox ────────────────────────────────────────── */
.ig-lb {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ig-lb[hidden] {
  display: none;
}

.ig-lb.ig-lb-visible {
  display: flex;
  animation: lbFadeIn 0.22s ease forwards;
}

.ig-lb.ig-lb-closing {
  animation: lbFadeOut 0.18s ease forwards;
}

@keyframes lbFadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

@keyframes lbFadeOut {
  from { opacity: 1; }
  to   { opacity: 0; }
}

.ig-lb-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.92);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  cursor: zoom-out;
}

.ig-lb-wrap {
  position: relative;
  z-index: 2;
  max-width: 92vw;
  max-height: 82vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ig-lb-img {
  max-width: 92vw;
  max-height: 82vh;
  object-fit: contain;
  border-radius: var(--radius-md, 14px);
  box-shadow: 0 40px 100px rgba(0, 0, 0, 0.65);
  display: block;
  animation: lbImgIn 0.25s cubic-bezier(0.34, 1.3, 0.64, 1) forwards;
}

@keyframes lbImgIn {
  from { transform: scale(0.92); opacity: 0.4; }
  to   { transform: scale(1);    opacity: 1;   }
}

/* Close button */
.ig-lb-close {
  position: fixed;
  top: 1.25rem;
  right: 1.25rem;
  z-index: 10;
  width: 46px;
  height: 46px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
  border: 1.5px solid rgba(255, 255, 255, 0.22);
  color: #fff;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s, transform 0.2s;
}

.ig-lb-close:hover {
  background: rgba(255, 255, 255, 0.25);
  transform: scale(1.1) rotate(90deg);
}

/* Prev / Next */
.ig-lb-prev,
.ig-lb-next {
  position: fixed;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  border: 1.5px solid rgba(255, 255, 255, 0.2);
  color: #fff;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
}

.ig-lb-prev { left: 1rem; }
.ig-lb-next { right: 1rem; }

.ig-lb-prev:hover {
  background: rgba(255,255,255,0.24);
  transform: translateY(-50%);
  box-shadow: 0 4px 20px rgba(0,0,0,0.3);
}
.ig-lb-next:hover {
  background: rgba(255,255,255,0.24);
  transform: translateY(-50%);
  box-shadow: 0 4px 20px rgba(0,0,0,0.3);
}

/* Footer — caption + counter */
.ig-lb-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 10;
  padding: 1rem 4rem 1.25rem;
  text-align: center;
  background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 100%);
  pointer-events: none;
}

.ig-lb-caption {
  display: none;
}

.ig-lb-counter {
  color: rgba(255, 255, 255, 0.5);
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  margin: 0;
}

/* ── Responsive ──────────────────────────────────────── */
@media (max-width: 640px) {
  .ig-swiper {
    height: clamp(280px, 70vw, 560px);
  }

  .ig-thumbs-swiper {
    height: 86px;
  }

  .ig-thumbs-swiper .swiper-slide {
    width: 78px !important;
    height: 72px;
  }

  .ig-lb-prev { left: 0.4rem; width: 44px; height: 44px; }
  .ig-lb-next { right: 0.4rem; width: 44px; height: 44px; }
  .ig-lb-footer { padding: 0.75rem 3rem 1rem; }
}
</style>

<script is:inline src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script is:inline>
(function () {
  var root = document.querySelector('.ig-root');
  if (!root) return;

  var slides = Array.from(root.querySelectorAll('.ig-swiper .swiper-slide'));
  var slideData = slides.map(function(s) {
    return { src: s.dataset.src, alt: s.dataset.alt, caption: s.dataset.caption || '' };
  });

  /* ── Swiper ──────────────────────────────────────── */
  var thumbsSwiper = new Swiper('.ig-thumbs-swiper', {
    slidesPerView: 'auto',
    spaceBetween: 8,
    freeMode: { enabled: true },
    watchSlidesProgress: true,
  });

  var mainSwiper = new Swiper('.ig-swiper', {
    loop: slideData.length > 1,
    speed: 420,
    navigation: {
      nextEl: '.swiper-button-next',
      prevEl: '.swiper-button-prev',
    },
    thumbs: { swiper: thumbsSwiper },
    on: {
      realIndexChange: function(sw) {
        var cur = root.querySelector('.ig-cur');
        if (cur) cur.textContent = sw.realIndex + 1;
      },
    },
  });

  /* ── Lightbox ────────────────────────────────────── */
  var lb      = document.getElementById('ig-lightbox');
  var lbImg   = lb.querySelector('.ig-lb-img');
  var lbCap   = lb.querySelector('.ig-lb-caption');
  var lbCnt   = lb.querySelector('.ig-lb-counter');
  var lbClose = lb.querySelector('.ig-lb-close');
  var lbPrev  = lb.querySelector('.ig-lb-prev');
  var lbNext  = lb.querySelector('.ig-lb-next');
  var lbBack  = lb.querySelector('.ig-lb-backdrop');
  var lbIndex = 0;

  function showLightbox(index) {
    lbIndex = ((index % slideData.length) + slideData.length) % slideData.length;
    var d = slideData[lbIndex];
    lbImg.src = d.src;
    lbImg.alt = d.alt;
    lbCap.textContent = d.caption;
    lbCnt.textContent = (lbIndex + 1) + ' / ' + slideData.length;
    lb.removeAttribute('hidden');
    lb.classList.remove('ig-lb-closing');
    lb.classList.add('ig-lb-visible');
    document.body.style.overflow = 'hidden';
    lbClose.focus();
  }

  function closeLightbox() {
    lb.classList.add('ig-lb-closing');
    lb.addEventListener('animationend', function handler() {
      lb.setAttribute('hidden', '');
      lb.classList.remove('ig-lb-visible', 'ig-lb-closing');
      document.body.style.overflow = '';
      lb.removeEventListener('animationend', handler);
    }, { once: true });
  }

  function lbGo(dir) {
    lbIndex = ((lbIndex + dir) + slideData.length) % slideData.length;
    var d = slideData[lbIndex];
    lbImg.style.opacity = '0';
    lbImg.style.transform = 'scale(0.95)';
    setTimeout(function() {
      lbImg.src = d.src;
      lbImg.alt = d.alt;
      lbCap.textContent = d.caption;
      lbCnt.textContent = (lbIndex + 1) + ' / ' + slideData.length;
      lbImg.style.transition = 'opacity 0.18s, transform 0.22s';
      lbImg.style.opacity = '1';
      lbImg.style.transform = 'scale(1)';
    }, 80);
  }

  root.querySelectorAll('.ig-open-btn').forEach(function(btn) {
    btn.addEventListener('click', function() { showLightbox(mainSwiper.realIndex); });
  });

  lbClose.addEventListener('click', closeLightbox);
  lbBack.addEventListener('click',  closeLightbox);
  lbPrev.addEventListener('click',  function() { lbGo(-1); });
  lbNext.addEventListener('click',  function() { lbGo(+1); });

  document.addEventListener('keydown', function(e) {
    if (lb.hasAttribute('hidden')) return;
    if (e.key === 'Escape')     closeLightbox();
    if (e.key === 'ArrowLeft')  lbGo(-1);
    if (e.key === 'ArrowRight') lbGo(+1);
  });
})();
</script>
