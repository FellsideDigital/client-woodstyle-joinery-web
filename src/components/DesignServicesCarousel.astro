---
// src/components/DesignServicesCarousel.astro
---

<style>
.carousel {
  display: flex;
  align-items: center;
  gap: 4rem;
  max-width: 1100px;
  margin: 0 auto;
}

/* LEFT: IMAGES */
.slides {
  position: relative;
  width: 600px;
  height: 420px;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-md);
}

.slides img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0;
  transition: opacity 0.6s ease-in-out;
}

.slides img.active {
  opacity: 1;
  z-index: 1;
}

/* RIGHT: TEXT LIST */
.nav-links {
  list-style: none;
  padding: 0;
  margin: 0;
}

.nav-link {
  display: flex;
  align-items: baseline;
  gap: 0.9rem;
  font-family: var(--font-heading);
  font-weight: 500;
  font-size: clamp(1.5rem, 2.6vw, 2rem);
  line-height: 1.35;
  color: var(--ink-muted);
  cursor: pointer;
  margin-bottom: 1.1rem;
  background: none;
  border: 0;
  text-align: left;
  padding: 0.2rem 0;
  transition: color 0.3s var(--ease), transform 0.3s var(--ease);
}

.nav-link .nav-index {
  font-size: 0.85rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  color: var(--accent);
  font-family: var(--font-body);
  font-variant-numeric: tabular-nums;
}

.nav-link:hover,
.nav-link:focus-visible {
  color: var(--primary);
  transform: translateX(6px);
  outline: none;
}

.nav-link.active {
  color: var(--ink);
  font-weight: 600;
  position: relative;
  padding-left: 1.1rem;
}

.nav-link.active::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0.4em;
  width: 4px;
  height: 1.1em;
  border-radius: 2px;
  background: var(--accent);
}

/* RESPONSIVE */
@media (max-width: 900px) {
  .carousel {
    flex-direction: column;
    gap: 2rem;
    text-align: center;
  }

  .slides {
    width: 100%;
    height: 360px;
  }

  .nav-link {
    font-size: 1.5rem;
  }

  .nav-link.active {
    padding-left: 0;
  }
  .nav-link.active::before {
    display: none;
  }
}
</style>

<div class="carousel">
  <div class="slides">
    <img
      src="/images/design/kitchen-design.jpg"
      alt="New Kitchens"
      class="active"
    />
    <img
      src="/images/design/garden-furniture-design.jpg"
      alt="Garden Furniture"
    />
    <img
      src="/images/design/garage-design.jpg"
      alt="Garage Design"
    />
  </div>

  <ul class="nav-links">
    <li>
      <button type="button" class="nav-link active" data-index="0">
        <span class="nav-index">01</span> New Kitchens or Replacements
      </button>
    </li>
    <li>
      <button type="button" class="nav-link" data-index="1">
        <span class="nav-index">02</span> Garden Furniture Design
      </button>
    </li>
    <li>
      <button type="button" class="nav-link" data-index="2">
        <span class="nav-index">03</span> Garage Design
      </button>
    </li>
  </ul>
</div>

<script>
const slides = document.querySelectorAll('.carousel .slides img');
const navLinks = document.querySelectorAll('.carousel .nav-link');

const activate = (index) => {
  slides.forEach((slide) => slide.classList.remove('active'));
  navLinks.forEach((nav) => nav.classList.remove('active'));
  slides[index].classList.add('active');
  navLinks[index].classList.add('active');
};

navLinks.forEach((link, index) => {
  link.addEventListener('click', () => activate(index));
  link.addEventListener('mouseenter', () => activate(index));
});
</script>
