---
// src/components/Footer.astro
---
<footer class="bg-dark text-secondary pt-5">
  <div class="container">

    <div class="row g-4 align-items-start">

      <!-- Location -->
      <div class="col-md-3">
        <h5 class="text-white fw-bold mb-3">Location</h5>

        <address class="mb-0 not-italic">
          <a
            href="https://www.google.com/maps/search/?api=1&query=Wood+Bank+Farm+Brisco+Carlisle+CA4+0QP"
            target="_blank"
            rel="noopener"
            class="footer-link d-inline-flex align-items-start gap-2 mb-1"
          >
            <span class="footer-icon">📍</span>
            <span>
              Wood Bank Farm, Brisco<br />
              Carlisle, Cumbria<br />
              United Kingdom, CA4 0QP
            </span>
          </a>
        </address>
      </div>

      <!-- Contact -->
      <div class="col-md-3">
        <h5 class="text-white fw-bold mb-3">Contact</h5>

        <p class="mb-2">
          <a
            href="tel:+441228512303"
            class="footer-link d-inline-flex align-items-center gap-2"
          >
            <span class="footer-icon">📞</span>
            01228 512303
          </a>
        </p>

        <p class="mb-0">
          <a
            href="mailto:info@woodstylejoinery.co.uk"
            class="footer-link d-inline-flex align-items-center gap-2"
          >
            <span class="footer-icon">✉️</span>
            info@woodstylejoinery.co.uk
          </a>
        </p>
      </div>

      <!-- Hours -->
      <div class="col-md-4">
        <h5 class="text-white fw-bold mb-3">Workshop Hours</h5>
        <p class="mb-1">Mon–Fri: 9am – 5pm</p>
        <p class="mb-1">Sat: 10am – 2pm</p>
        <p class="mb-0">Sun: Closed</p>
      </div>

      <!-- Badge -->
      <div class="col-md-2 text-center">
        <img
          src="/images/25-years-badge.png"
          alt="25 Years of Craftsmanship"
          class="img-fluid rounded shadow mb-2"
          style="max-height: 90px;"
        />
        <p class="small mb-0">Established Craft</p>
      </div>

    </div>

    <div class="border-top border-secondary mt-4 pt-3 text-center small">
      © 2026 Woodstyle Joinery. All rights reserved.
    </div>

  </div>
</footer>

<style>
.footer-link {
  color: rgba(255, 255, 255, 0.75);
  text-decoration: none;
  transition: color 0.2s ease, text-decoration 0.2s ease;
}

.footer-link:hover {
  color: #ffffff;
  text-decoration: underline;
}

.footer-icon {
  font-size: 0.95rem;
  opacity: 0.85;
  line-height: 1.2;
}
</style>
