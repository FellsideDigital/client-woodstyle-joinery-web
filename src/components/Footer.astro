---
// src/components/Footer.astro
---
<footer class="site-footer pt-5">
  <div class="container">

    <div class="row g-5 align-items-start">

      <!-- Brand -->
      <div class="col-lg-3 col-md-6">
        <img src="/images/site-logo.png" alt="Woodstyle Joinery Logo" height="44" class="mb-3 footer-logo" />
        <p class="footer-tagline mb-0">Bespoke joinery, handcrafted in Cumbria since 1988.</p>
      </div>

      <!-- Location -->
      <div class="col-lg-3 col-md-6">
        <h5 class="footer-heading mb-3">Location</h5>

        <address class="mb-0 not-italic">
          <a
            href="https://www.google.com/maps/search/?api=1&query=Wood+Bank+Farm+Brisco+Carlisle+CA4+0QP"
            target="_blank"
            rel="noopener"
            class="footer-link d-inline-flex align-items-start gap-2"
          >
            <i data-feather="map-pin" class="footer-icon"></i>
            <span>
              Wood Bank Farm, Brisco<br />
              Carlisle, Cumbria<br />
              United Kingdom, CA4 0QP
            </span>
          </a>
        </address>
      </div>

      <!-- Contact -->
      <div class="col-lg-3 col-md-6">
        <h5 class="footer-heading mb-3">Contact</h5>

        <p class="mb-2">
          <a
            href="tel:+441228512303"
            class="footer-link d-inline-flex align-items-center gap-2"
          >
            <i data-feather="phone" class="footer-icon"></i>
            01228 512303
          </a>
        </p>

        <p class="mb-0">
          <a
            href="mailto:info@woodstylejoinery.co.uk"
            class="footer-link d-inline-flex align-items-center gap-2"
          >
            <i data-feather="mail" class="footer-icon"></i>
            info@woodstylejoinery.co.uk
          </a>
        </p>
      </div>

      <!-- Hours -->
      <div class="col-lg-3 col-md-6">
        <h5 class="footer-heading mb-3">Workshop Hours</h5>
        <p class="mb-1 d-flex justify-content-between footer-hours"><span>Mon–Fri</span><span>9am – 5pm</span></p>
        <p class="mb-1 d-flex justify-content-between footer-hours"><span>Saturday</span><span>10am – 2pm</span></p>
        <p class="mb-0 d-flex justify-content-between footer-hours"><span>Sunday</span><span>Closed</span></p>
      </div>

    </div>

    <div class="footer-divider mt-5 pt-4 d-flex flex-column flex-sm-row justify-content-between align-items-center gap-2 text-center">
      <span class="small">© 2026 Woodstyle Joinery. All rights reserved.</span>
      <span class="small footer-credit">Established Craft · 35+ Years of Woodwork</span>
    </div>

  </div>
</footer>

<style>
.site-footer {
  background-color: var(--ink, #2b3328);
  color: rgba(255, 255, 255, 0.7);
  border-top: 3px solid var(--accent, #a87c4f);
  padding-bottom: 2rem;
}

.footer-heading {
  font-family: var(--font-heading, serif);
  color: #fff;
  font-weight: 600;
}

.footer-logo {
  filter: brightness(0) invert(1);
  opacity: 0.92;
}

.footer-tagline {
  font-size: 0.95rem;
  color: rgba(255, 255, 255, 0.6);
  max-width: 26ch;
}

.footer-link {
  color: rgba(255, 255, 255, 0.72);
  text-decoration: none;
  transition: color 0.2s ease, transform 0.2s ease;
}

.footer-link:hover {
  color: #ffffff;
  transform: translateX(2px);
}

.footer-icon {
  width: 17px;
  height: 17px;
  margin-top: 0.2rem;
  flex-shrink: 0;
  stroke: var(--secondary, #8b9d83);
}

.footer-hours {
  max-width: 220px;
  font-size: 0.92rem;
  color: rgba(255, 255, 255, 0.65);
}
.footer-hours span:first-child {
  color: rgba(255, 255, 255, 0.85);
  font-weight: 500;
}

.footer-divider {
  border-top: 1px solid rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.55);
}

.footer-credit {
  letter-spacing: 0.04em;
  text-transform: uppercase;
  font-size: 0.72rem;
  color: rgba(255, 255, 255, 0.4);
}
</style>
